---
---
<header id="site-header" class="bg-[#191A23]/90 backdrop-blur-md border-b border-[#B9FF66]/10 sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 py-4">

      <!-- LOGO -->
      <a href="/" aria-label="CLICOM — Retour à l'accueil" class="flex items-center gap-2 group focus:outline-none focus:ring-2 focus:ring-[#B9FF66] rounded-lg">
        <span class="w-8 h-8 bg-[#B9FF66] rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-[#191A23]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </span>
        <span class="font-extrabold text-xl text-white tracking-tight group-hover:text-[#B9FF66] transition-colors">
          CLICOM
        </span>
      </a>

      <!-- NAV DESKTOP -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Menu principal">
        <a href="/creation"        class="nav-link">Sites Web</a>
        <a href="/visibilite"      class="nav-link">Visibilité</a>
        <a href="/tarifs"          class="nav-link">Tarifs</a>
        <a href="/#blog"           class="nav-link">Blog</a>
        <a href="/equipe"          class="nav-link">L'Équipe</a>
      </nav>

      <!-- ACTIONS DESKTOP -->
      <div class="hidden lg:flex items-center gap-3">

        <!-- WhatsApp -->
        <a
          href="https://wa.me/41788238950?text=Bonjour%20CLICOM%2C%20je%20souhaite%20un%20audit%20gratuit."
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Nous contacter sur WhatsApp"
          class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#25D366]/10 border border-[#25D366]/20 text-[#25D366] hover:bg-[#25D366] hover:text-white hover:border-[#25D366] transition-all duration-200 group"
          title="WhatsApp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>

        <!-- Chatbot -->
        <button
          id="open-chatbot"
          aria-label="Ouvrir le chat avec notre assistant"
          class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#B9FF66]/10 border border-[#B9FF66]/20 text-[#B9FF66] hover:bg-[#B9FF66] hover:text-[#191A23] hover:border-[#B9FF66] transition-all duration-200"
          title="Chat avec notre assistant"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </button>

        <!-- Bouton Contact / CTA -->
        <a
          href="/#contact"
          class="flex items-center gap-2 bg-[#B9FF66] text-[#191A23] font-bold px-5 py-2.5 rounded-xl hover:bg-[#a3e655] transition-all focus:ring-2 focus:ring-[#B9FF66] focus:ring-offset-2 focus:ring-offset-[#191A23] shadow-lg shadow-[#B9FF66]/10 text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Audit Gratuit
        </a>
      </div>

      <!-- BURGER MOBILE -->
      <button
        id="menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Ouvrir le menu"
        class="lg:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 rounded-xl border border-white/10 hover:border-[#B9FF66]/30 transition-colors"
      >
        <span class="burger-line w-5 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="burger-line w-5 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="burger-line w-5 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
      </button>

    </div>
  </div>
</header>

<!-- MENU MOBILE -->
<div
  id="mobile-menu"
  class="hidden lg:hidden fixed inset-0 z-40 pt-[73px]"
  aria-hidden="true"
>
  <!-- Overlay -->
  <div id="menu-overlay" class="absolute inset-0 bg-[#191A23]/95 backdrop-blur-xl"></div>

  <!-- Panneau -->
  <nav class="relative z-10 max-w-sm mx-auto px-6 py-8 flex flex-col h-full" aria-label="Menu mobile">
    
    <div class="space-y-1 flex-1">
      <a href="/creation"   class="mobile-link" onclick="closeMenu()">
        <svg class="w-5 h-5 text-[#B9FF66]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Sites Web
      </a>
      <a href="/visibilite"  class="mobile-link" onclick="closeMenu()">
        <svg class="w-5 h-5 text-[#B9FF66]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Visibilité Locale
      </a>
      <a href="/tarifs"      class="mobile-link" onclick="closeMenu()">
        <svg class="w-5 h-5 text-[#B9FF66]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Tarifs
      </a>
      <a href="/#blog"       class="mobile-link" onclick="closeMenu()">
        <svg class="w-5 h-5 text-[#B9FF66]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        Blog
      </a>
      <a href="/equipe"      class="mobile-link" onclick="closeMenu()">
        <svg class="w-5 h-5 text-[#B9FF66]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        L'Équipe IA
      </a>
    </div>

    <!-- Actions mobile -->
    <div class="space-y-3 mt-8 pt-8 border-t border-white/10">
      <a
        href="https://wa.me/41788238950?text=Bonjour%20CLICOM%2C%20je%20souhaite%20un%20audit%20gratuit."
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-3 w-full py-4 rounded-xl bg-[#25D366]/10 border border-[#25D366]/20 text-[#25D366] font-bold hover:bg-[#25D366] hover:text-white transition-all"
        onclick="closeMenu()"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Écrire sur WhatsApp
      </a>
      <button
        id="open-chatbot-mobile"
        class="flex items-center justify-center gap-3 w-full py-4 rounded-xl bg-[#B9FF66]/10 border border-[#B9FF66]/20 text-[#B9FF66] font-bold hover:bg-[#B9FF66] hover:text-[#191A23] transition-all"
        onclick="closeMenu(); document.getElementById('open-chatbot').click()"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        Chat avec notre assistant
      </button>
      <a
        href="/#contact"
        class="flex items-center justify-center gap-2 w-full py-4 rounded-xl bg-[#B9FF66] text-[#191A23] font-bold hover:bg-[#a3e655] transition-all text-lg shadow-lg shadow-[#B9FF66]/10"
        onclick="closeMenu()"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Audit Gratuit — Rappel immédiat
      </a>
    </div>
  </nav>
</div>

<!-- CHATBOT MODAL -->
<div
  id="chatbot-modal"
  class="hidden fixed bottom-6 right-6 z-50 w-[360px] max-w-[calc(100vw-2rem)]"
  role="dialog"
  aria-modal="true"
  aria-label="Assistant CLICOM"
>
  <div class="bg-[#1f202b] rounded-3xl border border-[#B9FF66]/20 shadow-2xl shadow-black/50 overflow-hidden flex flex-col" style="max-height: 520px;">
    
    <!-- Header chatbot -->
    <div class="bg-[#191A23] px-5 py-4 flex items-center gap-3 border-b border-white/5">
      <div class="w-9 h-9 bg-[#B9FF66] rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-[#191A23]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-white font-bold text-sm">Assistant CLICOM</p>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 bg-[#B9FF66] rounded-full animate-pulse"></span>
          <span class="text-gray-500 text-xs">En ligne</span>
        </div>
      </div>
      <button id="close-chatbot" class="w-8 h-8 rounded-lg text-gray-500 hover:text-white hover:bg-white/5 flex items-center justify-center transition-colors" aria-label="Fermer le chat">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3" style="min-height: 280px;">
      <div class="flex gap-2">
        <div class="w-7 h-7 bg-[#B9FF66] rounded-full flex items-center justify-center flex-shrink-0 text-[#191A23] text-xs font-black">C</div>
        <div class="bg-[#191A23] rounded-2xl rounded-tl-sm px-4 py-3 max-w-[85%]">
          <p class="text-white text-sm leading-relaxed">Bonjour ! 👋 Je suis l'assistant de CLICOM.</p>
          <p class="text-gray-400 text-sm mt-2">Comment puis-je vous aider ? Choisissez une option ou tapez votre question :</p>
        </div>
      </div>

      <!-- Suggestions rapides -->
      <div id="quick-replies" class="flex flex-col gap-2 pl-9">
        <button class="quick-reply text-left px-4 py-2 rounded-xl border border-[#B9FF66]/20 bg-[#B9FF66]/5 text-[#B9FF66] text-xs font-medium hover:bg-[#B9FF66]/10 transition-colors">💰 Combien coûte un site ?</button>
        <button class="quick-reply text-left px-4 py-2 rounded-xl border border-[#B9FF66]/20 bg-[#B9FF66]/5 text-[#B9FF66] text-xs font-medium hover:bg-[#B9FF66]/10 transition-colors">📍 Comment apparaître sur Google Maps ?</button>
        <button class="quick-reply text-left px-4 py-2 rounded-xl border border-[#B9FF66]/20 bg-[#B9FF66]/5 text-[#B9FF66] text-xs font-medium hover:bg-[#B9FF66]/10 transition-colors">⚖️ Mon site est-il conforme à la nLPD ?</button>
        <button class="quick-reply text-left px-4 py-2 rounded-xl border border-[#B9FF66]/20 bg-[#B9FF66]/5 text-[#B9FF66] text-xs font-medium hover:bg-[#B9FF66]/10 transition-colors">📞 Parler à Mohamed Saber</button>
      </div>
    </div>

    <!-- Input -->
    <div class="p-4 border-t border-white/5 bg-[#191A23]">
      <form id="chat-form" class="flex gap-2">
        <input
          id="chat-input"
          type="text"
          placeholder="Votre question..."
          autocomplete="off"
          class="flex-1 bg-[#1f202b] border border-white/10 rounded-xl px-4 py-2.5 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-[#B9FF66] focus:ring-1 focus:ring-[#B9FF66] transition-colors"
        />
        <button
          type="submit"
          class="w-10 h-10 bg-[#B9FF66] text-[#191A23] rounded-xl flex items-center justify-center hover:bg-[#a3e655] transition-colors flex-shrink-0"
          aria-label="Envoyer"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </button>
      </form>
    </div>

  </div>
</div>

<!-- BOUTON FLOTTANT CHATBOT (visible en permanence) -->
<button
  id="chat-fab"
  aria-label="Ouvrir l'assistant CLICOM"
  class="fixed bottom-6 right-6 z-40 w-14 h-14 bg-[#B9FF66] text-[#191A23] rounded-2xl shadow-lg shadow-[#B9FF66]/30 flex items-center justify-center hover:bg-[#a3e655] hover:scale-110 transition-all duration-200"
>
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
  </svg>
  <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full border-2 border-[#191A23] animate-pulse"></span>
</button>

<style>
  .nav-link {
    color: #9ca3af;
    font-weight: 500;
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .nav-link:hover {
    color: #fff;
    background-color: rgba(255,255,255,0.05);
  }
  .nav-link:focus {
    outline: 2px solid #B9FF66;
    outline-offset: 2px;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #d1d5db;
    font-weight: 500;
    font-size: 1.125rem;
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid transparent;
    text-decoration: none;
    transition: all 0.2s;
  }
  .mobile-link:hover {
    color: #fff;
    background-color: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.05);
  }

  /* Burger animation */
  #menu-toggle.is-open .burger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #menu-toggle.is-open .burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #menu-toggle.is-open .burger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Header scroll effect */
  #site-header.scrolled {
    background-color: rgba(25, 26, 35, 0.98);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
</style>

<script>
  // ─── BURGER MENU ───────────────────────────────
  const toggle   = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  function closeMenu() {
    toggle.setAttribute('aria-expanded', 'false');
    toggle.classList.remove('is-open');
    mobileMenu.classList.add('hidden');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMenu();
    } else {
      toggle.setAttribute('aria-expanded', 'true');
      toggle.classList.add('is-open');
      mobileMenu.classList.remove('hidden');
      mobileMenu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  });

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // ─── SCROLL EFFECT ─────────────────────────────
  const header = document.getElementById('site-header')!;
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // ─── CHATBOT ───────────────────────────────────
  const chatbot     = document.getElementById('chatbot-modal')!;
  const fab         = document.getElementById('chat-fab')!;
  const openBtn     = document.getElementById('open-chatbot')!;
  const closeBtn    = document.getElementById('close-chatbot')!;
  const chatForm    = document.getElementById('chat-form')!;
  const chatInput   = document.getElementById('chat-input') as HTMLInputElement;
  const chatMessages = document.getElementById('chat-messages')!;

  // Réponses automatiques par mots-clés
  const botReplies: Record<string, string> = {
    'site': "Un site professionnel en Suisse romande coûte entre <strong>3 000 et 8 000 CHF</strong>. Les sites au rabais sont lourds et invisibles. Contactez-nous pour un devis net et transparent.",
    'coûte': "Un site professionnel coûte entre <strong>3 000 et 8 000 CHF</strong>. En dessous de 1 000 CHF/mois de budget marketing, votre entreprise reste invisible.",
