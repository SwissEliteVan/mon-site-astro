---
// src/components/Header.astro
---
<header class="bg-[#191A23]/95 backdrop-blur-md shadow-sm border-b border-[#B9FF66]/10 sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
    
    <!-- Logo -->
    <a href="/" class="font-bold text-2xl tracking-tight text-white flex items-center gap-2 hover:text-[#B9FF66] transition-colors focus:outline-none focus:ring-2 focus:ring-[#B9FF66] rounded-md">
      CLICOM
    </a>
    
    <!-- Bouton Mobile -->
    <button id="menu-toggle" aria-expanded="false" aria-label="Ouvrir le menu" class="lg:hidden p-2 min-h-[48px] min-w-[48px] text-gray-400 hover:text-[#B9FF66] focus:outline-none focus:ring-2 focus:ring-[#B9FF66] rounded-md transition-colors flex items-center justify-center">
      <svg id="menu-icon-open" class="w-7 h-7 block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
      <svg id="menu-icon-close" class="w-7 h-7 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>

    <!-- Navigation Desktop -->
    <nav class="hidden lg:flex items-center space-x-8" aria-label="Menu principal">
      <a href="/#services" class="text-gray-300 hover:text-[#B9FF66] font-medium transition-colors px-2 py-1">Services</a>
      <a href="/#equipe" class="text-gray-300 hover:text-[#B9FF66] font-medium transition-colors px-2 py-1">L'Équipe</a>
      <a href="/#preuve-sociale" class="text-gray-300 hover:text-[#B9FF66] font-medium transition-colors px-2 py-1">Cas Clients</a>
      <a href="/blog/" class="text-gray-300 hover:text-[#B9FF66] font-medium transition-colors px-2 py-1">Blog</a>
      <a href="/#contact" class="bg-[#B9FF66] text-[#191A23] hover:bg-[#a3e655] font-bold px-6 py-3 min-h-[48px] rounded-xl transition-all focus:ring-2 focus:ring-[#B9FF66] focus:ring-offset-2 focus:ring-offset-[#191A23] flex items-center justify-center">Audit Gratuit</a>
    </nav>

  </div>
</header>
