---
import ContactFormReact from './ContactFormReact';

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Parlons de votre projet", 
  subtitle = "Remplissez le formulaire ci-dessous et je vous recontacte dans les plus brefs délais." 
} = Astro.props;
---

<div class="contact-header">
  <span class="contact-badge">Consultation Stratégique Offerte</span>
  <h2 class="contact-title">{title}</h2>
  <p class="contact-subtitle">{subtitle}</p>
</div>

<ContactFormReact client:visible />

<style is:global>
  /* Conteneur principal */
  .contact-container {
    padding: 6rem 1.5rem;
    background: radial-gradient(circle at 50% 0%, rgba(185, 255, 102, 0.03) 0%, transparent 70%);
    position: relative;
  }

  .contact-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  /* En-tête */
  .contact-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .contact-badge {
    display: inline-block;
    background-color: rgba(185, 255, 102, 0.12);
    color: var(--color-brand-lime);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.375rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(185, 255, 102, 0.2);
    margin-bottom: 1.25rem;
  }

  .contact-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #ffffff, #d1d5db);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
  }

  .contact-subtitle {
    font-size: 1.125rem;
    color: #9ca3af;
    line-height: 1.6;
  }

  /* Formulaire */
  .contact-form {
    background-color: rgba(31, 32, 43, 0.7);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-3xl);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  @media (max-width: 640px) {
    .contact-form {
      padding: 1.75rem;
      gap: 1.25rem;
    }
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Labels */
  .form-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #cbd5e1;
    letter-spacing: 0.01em;
  }

  /* Input wrapper avec icône */
  .input-wrapper {
    position: relative;
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #6b7280;
    pointer-events: none;
    transition: color 0.2s ease;
  }

  .textarea-icon {
    top: 1rem;
    transform: none;
  }

  /* Champs de formulaire */
  .form-input {
    width: 100%;
    background-color: rgba(25, 26, 35, 0.8);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 0.875rem 1rem 0.875rem 2.75rem;
    color: #ffffff;
    font-size: 0.9375rem;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    outline: none;
  }

  .form-textarea {
    padding: 0.875rem 1rem 0.875rem 2.75rem;
    resize: vertical;
    min-height: 7rem;
    line-height: 1.6;
  }

  .form-input::placeholder {
    color: #4b5563;
  }

  .form-input:hover {
    border-color: var(--color-border-strong);
    background-color: rgba(25, 26, 35, 0.95);
  }

  .form-input:focus {
    border-color: var(--color-brand-lime);
    box-shadow: 0 0 0 4px rgba(185, 255, 102, 0.15);
    background-color: var(--color-brand-dark);
  }

  .form-input.error {
    border-color: var(--color-danger);
  }

  .error-message {
    color: var(--color-danger);
    font-size: 0.75rem;
    margin-top: 0.25rem;
  }

  /* CTA Bouton */
  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    background: linear-gradient(135deg, var(--color-brand-lime) 0%, #9de04e 100%);
    color: var(--color-brand-dark);
    font-weight: 800;
    font-size: 1.125rem;
    padding: 1.125rem 1.75rem;
    border-radius: var(--radius-xl);
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 8px 32px rgba(185, 255, 102, 0.25);
    margin-top: 1rem;
    letter-spacing: -0.01em;
  }

  .submit-btn:hover:not(:disabled) {
    background: linear-gradient(135deg, #a3e655 0%, #8ad43e 100%);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(185, 255, 102, 0.35);
  }

  .submit-btn:active:not(:disabled) {
    transform: translateY(1px);
  }

  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  /* Réassurance */
  .form-reassurance {
    display: flex;
    justify-content: center;
    gap: 1.75rem;
    flex-wrap: wrap;
    margin: 0.5rem 0;
  }

  .reassurance-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #6b7280;
  }

  @media (max-width: 540px) {
    .form-reassurance {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
  }

  /* Légal */
  .form-legal {
    text-align: center;
    font-size: 0.75rem;
    color: #4b5563;
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  .form-legal a {
    color: var(--color-brand-lime);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .form-legal a:hover {
    color: var(--color-brand-lime-hover);
  }
</style>