---
interface Props {
  title?: string;
  text?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title        = "L'argent est déjà sur la table.",
  text         = "En 1 heure de diagnostic gratuit, découvrez exactement combien vous perdez chaque mois — et comment le récupérer.",
  primaryLabel  = "Audit Gratuit — Rappel sous 2h",
  primaryHref   = "/#contact",
  secondaryLabel = "Voir les tarifs",
  secondaryHref  = "/#tarifs",
} = Astro.props;
---

<section class="cta-section">
  <!-- Halo décoratif -->
  <div class="cta-halo" aria-hidden="true"></div>

  <div class="cta-inner">
    <h2 class="cta-title">{title}</h2>
    <p class="cta-text">{text}</p>

    <div class="cta-actions">
      <a href={primaryHref} class="cta-btn-primary">
        <svg class="cta-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {primaryLabel}
      </a>
      <a href={secondaryHref} class="cta-btn-ghost">
        {secondaryLabel} →
      </a>
    </div>

    <!-- Rassurance -->
    <ul class="cta-trust" role="list">
      <li>
        <svg class="trust-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Sans engagement
      </li>
      <li>
        <svg class="trust-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Zéro frais cachés
      </li>
      <li>
        <svg class="trust-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Données protégées (nLPD)
      </li>
    </ul>
  </div>
</section>

<style>
  .cta-section {
    padding: 6rem 1rem;
    background-color: var(--color-brand-dark);
    position: relative;
    overflow: hidden;
  }

  /* Halo vert lime centré */
  .cta-halo {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 60% at 50% 50%,
      rgba(185,255,102,0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 44rem;
    margin: 0 auto;
    text-align: center;
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .cta-text {
    font-size: 1.125rem;
    color: #9ca3af;
    line-height: 1.7;
    max-width: 36rem;
    margin: 0 auto 2.5rem;
  }

  /* Boutons */
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-brand-lime);
    color: var(--color-brand-dark);
    font-weight: 800;
    font-size: 1rem;
    padding: 1rem 2rem;
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: var(--transition-base);
    box-shadow: var(--shadow-lime);
  }

  .cta-btn-primary:hover {
    background-color: var(--color-brand-lime-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lime-strong);
  }

  .cta-btn-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
  }

  .cta-btn-ghost {
    display: inline-flex;
    align-items: center;
    color: #9ca3af;
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: var(--transition-base);
  }

  .cta-btn-ghost:hover {
    color: #fff;
    border-color: var(--color-border-strong);
    background-color: rgba(255,255,255,0.04);
  }

  /* Liste de rassurance */
  .cta-trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cta-trust li {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: #6b7280;
    font-weight: 500;
  }

  .trust-icon {
    width: 1rem;
    height: 1rem;
    color: var(--color-brand-lime);
    flex-shrink: 0;
  }
</style>
