---
// src/components/Chatbot.astro
// Wrapper Astro pour ChatbotReact — hydratation client:load
// Le chatbot est visible immédiatement au chargement de la page
import ChatbotReact from './ChatbotReact.tsx';
---

<!--
  client:load : le composant est hydraté dès que le JS est disponible.
  Justification : le chatbot est un widget flottant global, toujours visible,
  qui doit répondre aux interactions utilisateur sans délai.
-->
<ChatbotReact client:load position="bottom-right" />