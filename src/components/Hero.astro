---
---
<section class="hero-section">
  <div class="hero-halo" aria-hidden="true"></div>

  <div class="hero-inner">
    <!-- Badge -->
    <div class="hero-badge">
      <span class="badge-dot" aria-hidden="true"></span>
      Agence Digitale — Suisse Romande
    </div>

    <!-- H1 -->
    <h1 class="hero-title">
      95 % des PME suisses ont un site.<br/>
      <span class="hero-title-accent">Moins de 15 % y amènent du monde.</span>
    </h1>

    <!-- Accroche -->
    <p class="hero-subtitle">
      Disperser de petits budgets ne marche pas. En dessous de
      <strong>1 000 CHF/mois</strong>, votre entreprise reste invisible.
      Notre seul but : <strong>faire sonner votre téléphone</strong>.
    </p>

    <!-- Stat rapide -->
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-number">73%</span>
        <span class="stat-desc">des Suisses vérifient Google Maps avant de venir</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item">
        <span class="stat-number">3,29 CHF</span>
        <span class="stat-desc">coût moyen par visiteur ciblé en Suisse romande</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item">
        <span class="stat-number">250 000 CHF</span>
        <span class="stat-desc">amende nLPD maximale pour un site non sécurisé</span>
      </div>
    </div>

    <!-- CTA -->
    <div class="hero-actions">
      <a href="/#contact" class="hero-btn-primary">
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Audit Gratuit — Rappel sous 2h
      </a>
      <a href="/#tarifs" class="hero-btn-ghost">
        Voir les tarifs →
      </a>
    </div>

    <!-- Rassurance -->
    <p class="hero-trust">
      Sans engagement · Zéro frais cachés · Données protégées (nLPD)
    </p>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    background-color: var(--color-brand-dark);
    padding: 8rem 1rem 6rem;
    text-align: center;
  }

  /* Halo décoratif */
  .hero-halo {
    position: absolute;
    top: -8rem;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(185,255,102,0.10) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-brand-lime-muted);
    border: 1px solid var(--color-border-lime);
    color: var(--color-brand-lime);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    margin-bottom: 2rem;
  }

  .badge-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background-color: var(--color-brand-lime);
    animation: pulse-lime 2s infinite;
  }

  /* Titre */
  .hero-title {
    font-size: var(--text-hero);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .hero-title-accent {
    background: linear-gradient(135deg, var(--color-brand-lime) 0%, #78ff00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Sous-titre */
  .hero-subtitle {
    font-size: 1.125rem;
    color: #9ca3af;
    line-height: 1.7;
    max-width: 42rem;
    margin: 0 auto 3rem;
  }

  .hero-subtitle strong {
    color: #fff;
    font-weight: 600;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    background-color: var(--color-brand-dark-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: 1.5rem 2rem;
    margin-bottom: 3rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-brand-lime);
    line-height: 1;
  }

  .stat-desc {
    font-size: 0.75rem;
    color: #6b7280;
    max-width: 10rem;
    line-height: 1.4;
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background-color: var(--color-border);
  }

  @media (max-width: 640px) {
    .stat-divider { display: none; }
    .hero-stats   { gap: 1rem; }
  }

  /* CTA */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-brand-lime);
    color: var(--color-brand-dark);
    font-weight: 800;
    font-size: 1rem;
    padding: 1rem 2rem;
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: var(--transition-base);
    box-shadow: var(--shadow-lime);
  }

  .hero-btn-primary:hover {
    background-color: var(--color-brand-lime-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lime-strong);
  }

  .btn-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
  }

  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    color: #9ca3af;
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: var(--transition-base);
  }

  .hero-btn-ghost:hover {
    color: #fff;
    border-color: var(--color-border-strong);
    background-color: rgba(255,255,255,0.04);
  }

  /* Mention rassurance */
  .hero-trust {
    font-size: 0.8rem;
    color: #4b5563;
    letter-spacing: 0.02em;
  }
</style>
