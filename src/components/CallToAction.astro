---
// src/components/CallToAction.astro
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
  <div class="bg-indigo-900 rounded-3xl p-8 md:p-16 text-center relative overflow-hidden shadow-2xl">
    <!-- Effet de fond -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-indigo-600 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
      <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-purple-600 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>
    </div>
    
    <div class="relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">Prêt à transformer votre site ?</h2>
      <p class="text-indigo-200 text-lg md:text-xl max-w-2xl mx-auto mb-10">Rejoignez les dizaines d'entreprises qui ont déjà fait le choix de l'architecture moderne et des performances optimales.</p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contact" class="rounded-xl bg-white text-indigo-900 px-8 py-4 font-bold hover:bg-indigo-50 transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-1">
          Lancer mon projet
        </a>
        <a href="#demo" class="rounded-xl bg-indigo-800 text-white px-8 py-4 font-bold border border-indigo-700 hover:bg-indigo-700 transition-colors">
          Voir la démonstration
        </a>
      </div>
    </div>
  </div>
</section>
