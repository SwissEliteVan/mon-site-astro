---
import type { HeaderProps } from '../../types/components';

/**
 * Composant Header - Barre de navigation principale
 * 
 * @prop {string} title - Titre principal affiché dans le header (défaut: 'Titre par défaut')
 * @prop {NavItem[]} navigation - Tableau d'éléments de navigation { label: string, href: string }
 */
const { title = 'Titre par défaut', navigation = [] } = Astro.props as HeaderProps;
---

<header class="header" x-data="{ mobileMenuOpen: false }">
  <div class="header-container">
    
    <!-- Logo -->
    <a href="/" class="logo" aria-label="CLICOM — Accueil">
      <span class="logo-mark">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </span>
      <span class="logo-text">CLICOM</span>
    </a>

    <!-- Navigation Desktop -->
    <nav class="nav-desktop" aria-label="Navigation principale">
      <a href="/" class="nav-link" aria-current="page">Accueil</a>
      <a href="/creation" class="nav-link">Création de sites</a>
      <a href="/visibilite" class="nav-link">Visibilité locale</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/tarifs" class="nav-link">Tarifs</a>
      <a href="/equipe" class="nav-link">L'Équipe</a>
    </nav>

    <!-- Actions (Dark mode + Contact) -->
    <div class="header-actions">
      <button id="theme-toggle" class="theme-toggle" aria-label="Changer le thème">
        <svg class="theme-icon sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="theme-icon moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      
      <a href="/#contact" class="btn-contact">
        <span>Nous contacter</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>

      <!-- Burger Button (Mobile) -->
      <button 
        class="burger" 
        :class="{ 'is-active': mobileMenuOpen }"
        @click="mobileMenuOpen = !mobileMenuOpen"
        aria-label="Menu"
        aria-expanded="false"
        :aria-expanded="mobileMenuOpen.toString()"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div 
      class="mobile-menu" 
      x-show="mobileMenuOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 -translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-4"
      x-cloak
    >
      <nav class="mobile-nav" aria-label="Navigation mobile">
        <a href="/" class="mobile-nav-link" @click="mobileMenuOpen = false">Accueil</a>
        <a href="/creation" class="mobile-nav-link" @click="mobileMenuOpen = false">Création de sites</a>
        <a href="/visibilite" class="mobile-nav-link" @click="mobileMenuOpen = false">Visibilité locale</a>
        <a href="/blog" class="mobile-nav-link" @click="mobileMenuOpen = false">Blog</a>
        <a href="/tarifs" class="mobile-nav-link" @click="mobileMenuOpen = false">Tarifs</a>
        <a href="/equipe" class="mobile-nav-link" @click="mobileMenuOpen = false">L'Équipe</a>
      </nav>
      <div class="mobile-footer">
        <a href="tel:+41788238950" class="mobile-phone">+41 78 823 89 50</a>
        <a href="mailto:contact@clicom.ch" class="mobile-email">contact@clicom.ch</a>
      </div>
    </div>
  </div>
</header>

<script>
  // Theme management - Dark Mode avec localStorage + préférences système
  (function() {
    const STORAGE_KEY = 'clicom-theme';
    const DARK_CLASS = 'dark';
    
    // Éléments
    const toggleBtn = document.getElementById('theme-toggle');
    
    // Vérifier si le dark mode est actif
    function isDarkMode() {
      return document.documentElement.classList.contains(DARK_CLASS);
    }
    
    // Appliquer le thème
    function setTheme(isDark) {
      if (isDark) {
        document.documentElement.classList.add(DARK_CLASS);
      } else {
        document.documentElement.classList.remove(DARK_CLASS);
      }
    }
    
    // Sauvegarder la préférence
    function saveThemePreference(isDark) {
      localStorage.setItem(STORAGE_KEY, isDark ? 'dark' : 'light');
    }
    
    // Lire la préférence sauvegardée
    function getSavedThemePreference() {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved === 'dark') return true;
      if (saved === 'light') return false;
      return null; // Pas de préférence sauvegardée
    }
    
    // Lire la préférence système
    function getSystemThemePreference() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches;
    }
    
    // Initialiser le thème
    function initTheme() {
      const saved = getSavedThemePreference();
      
      if (saved !== null) {
        // Utiliser la préférence sauvegardée
        setTheme(saved);
      } else {
        // Utiliser la préférence système
        setTheme(getSystemThemePreference());
      }
    }
    
    // Toggle le thème
    function toggleTheme() {
      const newTheme = !isDarkMode();
      setTheme(newTheme);
      saveThemePreference(newTheme);
    }
    
    // Écouter les changements de préférence système
    function listenToSystemThemeChanges() {
      const darkModeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      
      // Détecter si une préférence utilisateur existe
      const hasUserPreference = localStorage.getItem(STORAGE_KEY) !== null;
      
      // Ne réagir aux changements système que si l'utilisateur n'a pas de préférence
      if (!hasUserPreference) {
        darkModeMediaQuery.addEventListener('change', (e) => {
          setTheme(e.matches);
        });
      }
    }
    
    // Initialisation
    if (typeof window !== 'undefined') {
      initTheme();
      listenToSystemThemeChanges();
      
      // Ajouter l'event listener au bouton toggle
      if (toggleBtn) {
        toggleBtn.addEventListener('click', toggleTheme);
      }
    }
  })();
</script>

<style is:global>
  /* ======================================================= */
  /* HEADER PRINCIPAL                                        */
  /* ======================================================= */
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: var(--transition-base);
  }

  /* Dark mode header */
  :is(.dark .header) {
    background-color: rgba(25, 26, 35, 0.95);
    border-bottom-color: var(--color-border);
  }

  /* ======================================================= */
  /* CONTAINER                                              */
  /* ======================================================= */
  .header-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .header-container {
      padding: 0.75rem 1rem;
      gap: 1rem;
    }
  }

  /* ======================================================= */
  /* LOGO                                                    */
  /* ======================================================= */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    font-weight: 900;
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    color: #111827;
    transition: var(--transition-base);
    flex-shrink: 0;
  }

  :is(.dark .logo) {
    color: #ffffff;
  }

  .logo:hover {
    color: var(--color-brand-lime);
  }

  .logo-mark {
    width: 2rem;
    height: 2rem;
    background-color: var(--color-brand-lime);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
  }

  .logo-mark svg {
    stroke: var(--color-brand-dark);
    width: 1rem;
    height: 1rem;
  }

  .logo-text {
    font-family: var(--font-montserrat);
  }

  /* ======================================================= */
  /* NAVIGATION DESKTOP                                      */
  /* ======================================================= */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #4b5563;
    text-decoration: none;
    transition: var(--transition-base);
    position: relative;
  }

  :is(.dark .nav-link) {
    color: #9ca3af;
  }

  .nav-link:hover {
    color: var(--color-brand-lime);
  }

  /* Active link indicator */
  .nav-link[aria-current="page"] {
    color: var(--color-brand-lime);
    font-weight: 600;
  }

  .nav-link[aria-current="page"]::after {
    content: '';
    position: absolute;
    bottom: -0.375rem;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--color-brand-lime);
    border-radius: 2px;
  }

  /* ======================================================= */
  /* ACTIONS (Theme Toggle + Contact Button)                */
  /* ======================================================= */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  /* Theme Toggle Button */
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
    color: #4b5563;
  }

  :is(.dark .theme-toggle) {
    color: #9ca3af;
  }

  .theme-toggle:hover {
    border-color: var(--color-brand-lime);
    color: var(--color-brand-lime);
    transform: scale(1.05);
  }

  .theme-icon {
    transition: var(--transition-base);
  }

  /* Sun/Moon visibility */
  .sun-icon {
    display: block;
  }
  
  .moon-icon {
    display: none;
  }
  
  :is(.dark .sun-icon) {
    display: none;
  }
  
  :is(.dark .moon-icon) {
    display: block;
  }

  /* Contact Button */
  .btn-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-brand-lime);
    color: var(--color-brand-dark);
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: var(--transition-base);
    white-space: nowrap;
  }

  .btn-contact:hover {
    background-color: var(--color-brand-lime-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-lime);
  }

  @media (max-width: 640px) {
    .btn-contact span {
      display: none;
    }
    
    .btn-contact {
      padding: 0.5rem;
    }
  }

  /* ======================================================= */
  /* BURGER MENU (Mobile)                                   */
  /* ======================================================= */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 1.75rem;
    height: 1.25rem;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 60;
  }

  @media (max-width: 900px) {
    .burger {
      display: flex;
    }
  }

  .burger span {
    width: 100%;
    height: 2px;
    background-color: #111827;
    border-radius: 2px;
    transition: var(--transition-base);
  }

  :is(.dark .burger span) {
    background-color: #ffffff;
  }

  .burger.is-active span:nth-child(1) {
    transform: translateY(0.5625rem) rotate(45deg);
  }

  .burger.is-active span:nth-child(2) {
    opacity: 0;
  }

  .burger.is-active span:nth-child(3) {
    transform: translateY(-0.5625rem) rotate(-45deg);
  }

  /* ======================================================= */
  /* MOBILE MENU (Overlay)                                  */
  /* ======================================================= */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    z-index: 50;
    padding: 5rem 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow-y: auto;
  }

  :is(.dark .mobile-menu) {
    background-color: rgba(25, 26, 35, 0.98);
  }

  /* Alpine.js cloak */
  [x-cloak] {
    display: none !important;
  }

  /* Transition classes */
  .transition {
    transition-property: opacity, transform;
  }
  
  .duration-300 {
    transition-duration: 300ms;
  }
  
  .duration-200 {
    transition-duration: 200ms;
  }
  
  .ease-out {
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .ease-in {
    transition-timing-function: cubic-bezier(0.4, 0, 1, 1);
  }
  
  .opacity-0 {
    opacity: 0;
  }
  
  .opacity-100 {
    opacity: 1;
  }
  
  .-translate-y-4 {
    transform: translateY(-1rem);
  }
  
  .translate-y-0 {
    transform: translateY(0);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .mobile-nav-link {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
    text-decoration: none;
    transition: var(--transition-base);
    padding: 0.5rem;
  }

  :is(.dark .mobile-nav-link) {
    color: #ffffff;
  }

  .mobile-nav-link:hover {
    color: var(--color-brand-lime);
    transform: translateX(4px);
  }

  .mobile-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .mobile-phone,
  .mobile-email {
    font-size: 0.875rem;
    color: #6b7280;
    text-decoration: none;
    transition: var(--transition-base);
  }

  :is(.dark .mobile-phone, .dark .mobile-email) {
    color: #9ca3af;
  }

  .mobile-phone:hover,
  .mobile-email:hover {
    color: var(--color-brand-lime);
  }
</style>