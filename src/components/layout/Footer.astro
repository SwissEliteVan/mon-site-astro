---
// Footer.astro - CLICOM Design System v4
// Compatible Tailwind v4 avec Dark Mode
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- ======================================================= -->
    <!-- BRAND : Logo + tagline                                  -->
    <!-- ======================================================= -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="CLICOM — Accueil">
        <span class="footer-logo-mark">
          <svg width="16" height="16" fill="none" stroke="#191A23" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </span>
        CLICOM
      </a>
      <p class="footer-tagline">L'Humain orchestre, l'IA exécute.</p>
    </div>

    <!-- ======================================================= -->
    <!-- NAVIGATION PRINCIPALE : Liens organisés par colonnes    -->
    <!-- ======================================================= -->
    <nav class="footer-nav" aria-label="Liens du bas de page">

      <!-- Colonne 1 : Services -->
      <div class="footer-col">
        <p class="footer-col-title">Services</p>
        <a href="/creation"   class="footer-link">Création de sites</a>
        <a href="/visibilite" class="footer-link">Visibilité locale</a>
        <a href="/tarifs"     class="footer-link">Tarifs</a>
        <a href="/equipe"     class="footer-link">L'Équipe</a>
      </div>

      <!-- Colonne 2 : Ressources -->
      <div class="footer-col">
        <p class="footer-col-title">Ressources</p>
        <a href="/blog"       class="footer-link">Blog</a>
        <a href="/#contact"   class="footer-link">Contact</a>
      </div>

      <!-- Colonne 3 : SEO Local (villes de Suisse Romande) -->
      <div class="footer-col">
        <p class="footer-col-title">SEO Local</p>
        <a href="/lausanne"    class="footer-link">Lausanne</a>
        <a href="/geneve"      class="footer-link">Genève</a>
        <a href="/vevey"       class="footer-link">Vevey</a>
        <a href="/montreux"    class="footer-link">Montreux</a>
        <a href="/nyon"        class="footer-link">Nyon</a>
        <a href="/yverdon"     class="footer-link">Yverdon-les-Bains</a>
        <a href="/fribourg"    class="footer-link">Fribourg</a>
        <a href="/neuchatel"   class="footer-link">Neuchâtel</a>
        <a href="/sion"        class="footer-link">Sion</a>
        <a href="/martigny"    class="footer-link">Martigny</a>
        <a href="/renens"      class="footer-link">Renens</a>
        <a href="/pully"       class="footer-link">Pully</a>
      </div>

      <!-- Colonne 4 : Légal -->
      <div class="footer-col">
        <p class="footer-col-title">Légal</p>
        <a href="/mentions-legales"          class="footer-link">Mentions légales</a>
        <a href="/politique-confidentialite" class="footer-link">Confidentialité (nLPD)</a>
        <a href="/conditions-generales"      class="footer-link">Conditions générales</a>
        <a href="/protection-donnees"        class="footer-link">Protection des données</a>
      </div>

    </nav>

    <!-- ======================================================= -->
    <!-- CONTACT DIRECT : Téléphone, WhatsApp, Email, adresse    -->
    <!-- ======================================================= -->
    <div class="footer-contact">
      <a href="tel:+41788238950" class="footer-contact-link footer-contact-phone">
        <svg class="contact-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        +41 78 823 89 50
      </a>
      <a href="https://wa.me/41788238950" target="_blank" rel="noopener noreferrer" class="footer-contact-link footer-contact-whatsapp">
        <svg class="contact-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        WhatsApp
      </a>
      <a href="mailto:contact@clicom.ch" class="footer-contact-link footer-contact-email">
        <svg class="contact-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        contact@clicom.ch
      </a>
      <span class="footer-location">
        <svg class="location-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Corseaux, Vaud · Suisse
      </span>
    </div>

  </div>

  <!-- ======================================================= -->
  <!-- COPYRIGHT & LIENS LÉGAUX                                -->
  <!-- ======================================================= -->
  <div class="footer-bottom">
    <span>&copy; {new Date().getFullYear()} CLICOM · Agence Marketing Digital · Suisse Romande</span>
    <span class="footer-sep" aria-hidden="true">·</span>
    <a href="/mentions-legales" class="footer-bottom-link">Mentions légales</a>
    <span class="footer-sep" aria-hidden="true">·</span>
    <a href="/politique-confidentialite" class="footer-bottom-link">Confidentialité (nLPD)</a>
    <span class="footer-sep" aria-hidden="true">·</span>
    <a href="/conditions-generales" class="footer-bottom-link">CGV</a>
  </div>
</footer>

<style is:global>
  /* ======================================================= */
  /* FOOTER PRINCIPAL                                        */
  /* ======================================================= */
  .site-footer {
    background-color: var(--color-brand-dark);
    border-top: 1px solid var(--color-brand-lime);
    margin-top: auto;
  }

  /* Dark mode support */
  :is(.dark .site-footer) {
    background-color: var(--color-brand-dark);
  }

  /* ======================================================= */
  /* GRILLE PRINCIPALE (Desktop : Logo | Nav | Contact)      */
  /* ======================================================= */
  .footer-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2.5rem;
    display: grid;
    grid-template-columns: 1fr 3fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ======================================================= */
  /* RESPONSIVE : Tablette                                   */
  /* ======================================================= */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* ======================================================= */
  /* RESPONSIVE : Mobile                                     */
  /* ======================================================= */
  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2.5rem 1.25rem 2rem;
    }
  }

  /* ======================================================= */
  /* BRAND : Logo et tagline                                 */
  /* ======================================================= */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 900;
    font-size: 1.125rem;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: var(--transition-base);
    width: fit-content;
  }

  .footer-logo:hover {
    color: var(--color-brand-lime);
  }

  .footer-logo-mark {
    width: 1.75rem;
    height: 1.75rem;
    background-color: var(--color-brand-lime);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .footer-logo-mark svg {
    stroke: var(--color-brand-dark);
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: #6b7280;
    font-style: italic;
    line-height: 1.5;
    max-width: 16rem;
  }

  /* Dark mode tagline */
  :is(.dark .footer-tagline) {
    color: #9ca3af;
  }

  /* ======================================================= */
  /* NAVIGATION : Grille des colonnes                        */
  /* ======================================================= */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 640px) {
    .footer-nav {
      gap: 1.5rem;
    }
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-col-title {
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-brand-lime);
    margin-bottom: 0.25rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: #6b7280;
    text-decoration: none;
    transition: var(--transition-base);
    width: fit-content;
  }

  .footer-link:hover {
    color: #ffffff;
    transform: translateX(2px);
  }

  /* Dark mode links */
  :is(.dark .footer-link) {
    color: #9ca3af;
  }

  :is(.dark .footer-link:hover) {
    color: #ffffff;
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--color-brand-lime);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ======================================================= */
  /* CONTACT : Téléphone, WhatsApp, email, localisation      */
  /* ======================================================= */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #9ca3af;
    text-decoration: none;
    transition: var(--transition-base);
    width: fit-content;
  }

  .footer-contact-link:hover {
    color: #ffffff;
    transform: translateX(2px);
  }

  /* Phone link highlight */
  .footer-contact-phone {
    color: var(--color-brand-lime);
    font-size: 1rem;
  }

  .footer-contact-phone:hover {
    color: var(--color-brand-lime-hover);
  }

  /* WhatsApp link highlight */
  .footer-contact-whatsapp {
    color: #25D366;
  }

  .footer-contact-whatsapp:hover {
    color: #20ba58;
  }

  /* Email link */
  .footer-contact-email:hover {
    color: #ffffff;
  }

  .contact-icon,
  .location-icon {
    flex-shrink: 0;
  }

  .footer-location {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #6b7280;
    margin-top: 0.5rem;
  }

  :is(.dark .footer-location) {
    color: #4b5563;
  }

  /* ======================================================= */
  /* COPYRIGHT : Barre du bas                                */
  /* ======================================================= */
  .footer-bottom {
    border-top: 1px solid #1f202b;
    padding: 1.25rem 1.5rem;
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #6b7280;
  }

  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
      padding: 1rem 1.25rem;
    }
    
    .footer-sep {
      display: none;
    }
  }

  .footer-sep {
    color: #374151;
  }

  .footer-bottom-link {
    color: #6b7280;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .footer-bottom-link:hover {
    color: var(--color-brand-lime);
  }

  /* Dark mode bottom */
  :is(.dark .footer-bottom) {
    border-top-color: #2a2b38;
  }

  :is(.dark .footer-bottom, .dark .footer-bottom-link) {
    color: #4b5563;
  }

  :is(.dark .footer-bottom-link:hover) {
    color: var(--color-brand-lime);
  }
</style>