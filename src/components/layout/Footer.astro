---
// Footer.astro — CLICOM Design System v5
// Tailwind pur — zéro CSS arbitraire — responsive sm:/md:/lg:
---

<footer class="w-full bg-brand-dark border-t border-lime/30">

  <!-- Grille principale -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1fr_3fr_1fr] gap-10 lg:gap-12 items-start">

    <!-- ── Brand ── -->
    <div class="flex flex-col gap-3 sm:col-span-2 lg:col-span-1">
      <a href="/" class="inline-flex items-center gap-2 font-heading font-black text-lg text-white tracking-widest hover:text-lime transition-colors w-fit" aria-label="CLICOM — Accueil">
        <span class="w-7 h-7 bg-lime rounded-md flex items-center justify-center flex-shrink-0" aria-hidden="true">
          <svg width="14" height="14" fill="none" stroke="#191A23" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </span>
        CLICOM
      </a>
      <p class="text-[0.8125rem] text-gray-500 italic leading-relaxed max-w-[16rem]">
        L'Humain orchestre, l'IA exécute.
      </p>
    </div>

    <!-- ── Navigation par colonnes ── -->
    <nav aria-label="Liens du bas de page" class="grid grid-cols-2 sm:grid-cols-4 gap-8">

      <!-- Services -->
      <div class="flex flex-col gap-2">
        <p class="text-[0.6875rem] font-extrabold tracking-[0.10em] uppercase text-lime mb-1">Services</p>
        <a href="/creation"   class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Création de sites</a>
        <a href="/visibilite" class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Visibilité locale</a>
        <a href="/tarifs"     class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Tarifs</a>
        <a href="/equipe"     class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">L'Équipe</a>
      </div>

      <!-- Ressources -->
      <div class="flex flex-col gap-2">
        <p class="text-[0.6875rem] font-extrabold tracking-[0.10em] uppercase text-lime mb-1">Ressources</p>
        <a href="/blog"      class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Blog</a>
        <a href="/#contact"  class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Contact</a>
      </div>

      <!-- SEO Local -->
      <div class="flex flex-col gap-2">
        <p class="text-[0.6875rem] font-extrabold tracking-[0.10em] uppercase text-lime mb-1">SEO Local</p>
        <a href="/lausanne"  class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Lausanne</a>
        <a href="/geneve"    class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Genève</a>
        <a href="/vevey"     class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Vevey</a>
        <a href="/montreux"  class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Montreux</a>
        <a href="/nyon"      class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Nyon</a>
        <a href="/yverdon"   class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Yverdon-les-Bains</a>
        <a href="/fribourg"  class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Fribourg</a>
        <a href="/neuchatel" class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Neuchâtel</a>
        <a href="/sion"      class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Sion</a>
        <a href="/martigny"  class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Martigny</a>
        <a href="/renens"    class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Renens</a>
        <a href="/pully"     class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Pully</a>
      </div>

      <!-- Légal — FIXED: /conditions-generales → /mentions-legales | /protection-donnees → /politique-confidentialite -->
      <div class="flex flex-col gap-2">
        <p class="text-[0.6875rem] font-extrabold tracking-[0.10em] uppercase text-lime mb-1">Légal</p>
        <a href="/mentions-legales"          class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Mentions légales</a>
        <a href="/politique-confidentialite" class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Confidentialité (nLPD)</a>
        <a href="/mentions-legales"          class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Conditions générales</a>
        <a href="/politique-confidentialite" class="text-sm text-gray-500 hover:text-white hover:translate-x-0.5 transition-all w-fit">Protection des données</a>
      </div>

    </nav>

    <!-- ── Contact direct ── -->
    <div class="flex flex-col gap-3">
      <a href="tel:+41788238950"
        class="inline-flex items-center gap-2.5 text-base font-bold text-lime hover:text-lime-hover transition-colors w-fit group">
        <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        +41 78 823 89 50
      </a>

      <a href="https://wa.me/41788238950" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 text-sm font-semibold text-[#25D366] hover:text-[#20ba58] transition-colors w-fit">
        <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        WhatsApp
      </a>

      <a href="mailto:contact@clicom.ch"
        class="inline-flex items-center gap-2.5 text-sm font-semibold text-gray-400 hover:text-white transition-colors w-fit">
        <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        hello@clicom.ch
      </a>

      <span class="inline-flex items-center gap-2 text-[0.8rem] text-gray-600 mt-1">
        <svg class="w-3.5 h-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Corseaux, Vaud · Suisse
      </span>
    </div>

  </div>

  <!-- Barre copyright -->
  <div class="border-t border-brand-dark-3 px-4 sm:px-6 lg:px-8 py-5">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row flex-wrap items-center justify-center gap-2 sm:gap-3 text-[0.75rem] text-gray-600">
      <span>© {new Date().getFullYear()} CLICOM · Agence Marketing Digital · Suisse Romande</span>
      <span aria-hidden="true" class="hidden sm:inline text-gray-700">·</span>
      <a href="/mentions-legales"          class="hover:text-lime transition-colors">Mentions légales</a>
      <span aria-hidden="true" class="hidden sm:inline text-gray-700">·</span>
      <a href="/politique-confidentialite" class="hover:text-lime transition-colors">Confidentialité (nLPD)</a>
      <span aria-hidden="true" class="hidden sm:inline text-gray-700">·</span>
      <a href="/mentions-legales"          class="hover:text-lime transition-colors">CGV</a>
    </div>
  </div>

</footer>