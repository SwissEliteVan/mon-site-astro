---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 border-t border-slate-800 text-slate-300 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      
      <!-- Colonne 1 : Résumé de l'agence -->
      <div class="lg:col-span-2">
        <a href="/" class="font-bold text-2xl tracking-tight text-white flex items-center gap-2 hover:text-indigo-400 transition-colors mb-6 inline-flex">
          <svg class="w-8 h-8 text-indigo-500" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13.5h-13L12 6.5z"/>
          </svg>
          Clicom<span class="text-indigo-500">.</span>
        </a>
        <p class="text-slate-400 leading-relaxed max-w-sm mb-6">
          L'agence de marketing digital 100% suisse qui refuse le statu quo. Nous utilisons l'intelligence artificielle et des stratégies ROI pour accélérer la croissance des PME romandes.
        </p>
      </div>

      <!-- Colonne 2 : Liens Rapides -->
      <div>
        <h3 class="text-white font-bold mb-6 uppercase tracking-wider text-sm">Liens Rapides</h3>
        <ul class="space-y-4">
          <li><a href="/services" class="hover:text-indigo-400 transition-colors focus:outline-none focus:underline">Nos Services</a></li>
          <li><a href="/realisations" class="hover:text-indigo-400 transition-colors focus:outline-none focus:underline">Cas Clients</a></li>
          <li><a href="/faq" class="hover:text-indigo-400 transition-colors focus:outline-none focus:underline">Questions Fréquentes</a></li>
          <li><a href="/blog" class="hover:text-indigo-400 transition-colors focus:outline-none focus:underline">Blog Digital</a></li>
        </ul>
      </div>

      <!-- Colonne 3 : Contact -->
      <div>
        <h3 class="text-white font-bold mb-6 uppercase tracking-wider text-sm">Nous Contacter</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3 group">
            <svg class="w-5 h-5 text-indigo-500 mt-0.5 flex-shrink-0 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="tel:+41788238950" class="hover:text-white transition-colors group-hover:text-white font-medium">078 823 89 50</a>
          </li>
          <li class="flex items-start gap-3 group">
            <svg class="w-5 h-5 text-indigo-500 mt-0.5 flex-shrink-0 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:hello@clicom.ch" class="hover:text-white transition-colors group-hover:text-white font-medium">hello@clicom.ch</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-indigo-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Suisse romande (Vaud)</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Séparateur et zone légale -->
    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-slate-500">
      <p>&copy; {currentYear} Clicom Sàrl. Tous droits réservés.</p>
      <div class="flex space-x-6">
        <a href="/mentions-legales" class="hover:text-indigo-400 transition-colors focus:outline-none focus:underline">Mentions légales & Politique nLPD</a>
      </div>
    </div>
  </div>
</footer>
