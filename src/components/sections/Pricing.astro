---
// src/components/sections/Pricing.astro
// Charte Clicom — Tailwind pur, zéro CSS arbitraire
---

<section class="w-full bg-brand-dark py-24 px-4">
  <div class="max-w-5xl mx-auto">

    <!-- En-tête -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center rounded-full px-4 py-1.5 text-xs font-bold tracking-widest uppercase text-lime bg-lime-muted border border-lime/25 mb-6">
        Investissement
      </div>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white tracking-tight mb-4">
        Des tarifs clairs, orientés rentabilité
      </h2>
      <p class="text-base text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Pas de coûts cachés, pas de mauvaises surprises. Choisissez le partenariat qui correspond à vos ambitions de croissance en Suisse.
      </p>
    </div>

    <!-- Grille 3 cartes -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-center">

      <!-- Pack 1 : Vitrine -->
      <div class="bg-brand-dark-2 border border-border rounded-3xl p-8 hover:border-border-lime hover:shadow-lime transition-all duration-300 flex flex-col">
        <h3 class="font-heading text-xl font-bold text-white mb-2">Site Vitrine Standard</h3>
        <p class="text-gray-500 text-sm mb-6 leading-relaxed">La fondation parfaite pour asseoir votre crédibilité locale.</p>
        <div class="mb-6 flex items-baseline gap-2">
          <span class="text-sm font-bold text-gray-500">Dès</span>
          <span class="text-4xl font-extrabold text-white">1'500</span>
          <span class="text-gray-500 font-medium">CHF</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm text-gray-400 flex-1">
          {[
            'Design vitrine ultra-rapide',
            'Conformité stricte nLPD',
            'Hébergement sécurisé suisse',
          ].map(feat => (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-lime flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              {feat}
            </li>
          ))}
        </ul>
        <a href="/#contact" class="block text-center w-full rounded-xl bg-white/5 border border-border text-white font-bold py-3 hover:bg-white/10 hover:border-border-strong transition-colors">
          Demander un devis
        </a>
      </div>

      <!-- Pack 2 : Performance & ROI (mis en avant) -->
      <div class="relative bg-lime rounded-3xl p-8 shadow-lime-lg md:-translate-y-4 flex flex-col group">
        <!-- Badge Recommandé -->
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="bg-brand-dark text-lime text-2xs font-bold uppercase tracking-widest py-1.5 px-4 rounded-full border border-lime/30 shadow-lime whitespace-nowrap">
            ⭐ Recommandé
          </span>
        </div>
        <h3 class="font-heading text-xl font-bold text-brand-dark mb-2 mt-2">Performance & ROI</h3>
        <p class="text-brand-dark/70 text-sm mb-6 leading-relaxed">Le système complet pour générer un flux de clients continu.</p>
        <div class="mb-6 flex items-baseline gap-2">
          <span class="text-sm font-bold text-brand-dark/70">Dès</span>
          <span class="text-4xl md:text-5xl font-extrabold text-brand-dark">3'500</span>
          <span class="text-brand-dark/70 font-medium">CHF</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm text-brand-dark flex-1">
          {[
            'Design sur-mesure & Copywriting',
            'Optimisation SEO locale poussée',
            'Automatisation IA de l\'acquisition',
            'Maintenance & Support prioritaire',
          ].map(feat => (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-brand-dark flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              {feat}
            </li>
          ))}
        </ul>
        <a href="/#contact" class="block text-center w-full rounded-xl bg-brand-dark text-lime font-bold py-4 hover:bg-brand-dark-2 transition-colors group-hover:scale-[1.02] transform">
          Lancer ma croissance
        </a>
      </div>

      <!-- Pack 3 : Sur-mesure -->
      <div class="bg-brand-dark-2 border border-border rounded-3xl p-8 hover:border-border-lime hover:shadow-lime transition-all duration-300 flex flex-col">
        <h3 class="font-heading text-xl font-bold text-white mb-2">Sur-mesure & E-com</h3>
        <p class="text-gray-500 text-sm mb-6 leading-relaxed">Pour les projets complexes ou les boutiques en ligne.</p>
        <div class="mb-6">
          <span class="text-4xl font-extrabold text-white">Sur devis</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm text-gray-400 flex-1">
          {[
            'Boutique E-commerce complète',
            'Développement d\'applications Web',
            'Architectures API / Intégration CRM',
          ].map(feat => (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-lime flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              {feat}
            </li>
          ))}
        </ul>
        <a href="/#contact" class="block text-center w-full rounded-xl bg-white/5 border border-border text-white font-bold py-3 hover:bg-white/10 hover:border-border-strong transition-colors">
          Contacter les experts
        </a>
      </div>

    </div>
  </div>
</section>
