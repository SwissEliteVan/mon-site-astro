---
---

<section class="relative overflow-hidden bg-brand-dark py-32 pb-24 px-4 text-center">

  <!-- Halo décoratif -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-[radial-gradient(ellipse_at_center,rgba(185,255,102,0.10)_0%,transparent_65%)]"
  ></div>

  <div class="relative z-10 max-w-4xl mx-auto">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-lime-muted border border-lime/25 text-lime text-[0.8125rem] font-bold tracking-[0.05em] uppercase px-4 py-1.5 rounded-full mb-8">
      <span class="w-2 h-2 rounded-full bg-lime animate-pulse" aria-hidden="true"></span>
      Agence Digitale — Suisse Romande
    </div>

    <!-- H1 -->
    <h1 class="font-heading text-hero font-extrabold text-white leading-[1.15] tracking-tight mb-6">
      95 % des PME suisses ont un site.<br/>
      <span class="text-gradient-lime">Moins de 15 % y amènent du monde.</span>
    </h1>

    <!-- Sous-titre -->
    <p class="text-lg text-gray-400 leading-relaxed max-w-2xl mx-auto mb-12">
      Disperser de petits budgets ne marche pas. En dessous de
      <strong class="text-white font-semibold">1 000 CHF/mois</strong>, votre entreprise reste invisible.
      Notre seul but : <strong class="text-white font-semibold">faire sonner votre téléphone</strong>.
    </p>

    <!-- Stats -->
    <div class="flex flex-wrap items-center justify-center gap-6 bg-brand-dark-2 border border-border rounded-3xl px-8 py-6 mb-12">

      <div class="flex flex-col items-center gap-1 text-center">
        <span class="text-2xl font-extrabold text-lime leading-none">73%</span>
        <span class="text-xs text-gray-500 max-w-[10rem] leading-snug">des Suisses vérifient Google Maps avant de venir</span>
      </div>

      <div aria-hidden="true" class="hidden sm:block w-px h-10 bg-border"></div>

      <div class="flex flex-col items-center gap-1 text-center">
        <span class="text-2xl font-extrabold text-lime leading-none">3,29 CHF</span>
        <span class="text-xs text-gray-500 max-w-[10rem] leading-snug">coût moyen par visiteur ciblé en Suisse romande</span>
      </div>

      <div aria-hidden="true" class="hidden sm:block w-px h-10 bg-border"></div>

      <div class="flex flex-col items-center gap-1 text-center">
        <span class="text-2xl font-extrabold text-lime leading-none">250 000 CHF</span>
        <span class="text-xs text-gray-500 max-w-[10rem] leading-snug">amende nLPD maximale pour un site non sécurisé</span>
      </div>

    </div>

    <!-- CTA -->
    <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
      <a
        href="/#contact"
        class="inline-flex items-center gap-2 bg-lime text-brand-dark font-extrabold text-base px-8 py-4 rounded-xl hover:bg-lime-hover hover:-translate-y-0.5 transition-all shadow-lime"
      >
        <svg class="w-[1.125rem] h-[1.125rem] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Audit Gratuit — Rappel sous 2h
      </a>
      <a
        href="/#tarifs"
        class="inline-flex items-center text-gray-400 font-semibold text-[0.9375rem] px-6 py-4 rounded-xl border border-border hover:text-white hover:border-border-strong hover:bg-white/[0.04] transition-all"
      >
        Voir les tarifs →
      </a>
    </div>

    <!-- Rassurance -->
    <p class="text-[0.8rem] text-gray-600 tracking-[0.02em]">
      Sans engagement · Zéro frais cachés · Données protégées (nLPD)
    </p>

  </div>
</section>
