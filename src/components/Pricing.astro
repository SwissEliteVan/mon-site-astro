---
// src/components/Pricing.astro
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
  <div class="text-center mb-16">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight">Tarifs transparents</h2>
    <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">Choisissez l'architecture qui correspond à l'envergure de votre projet.</p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center max-w-5xl mx-auto">
    <!-- Basic Plan -->
    <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm">
      <h3 class="text-lg font-semibold text-slate-900 mb-2">Essentiel</h3>
      <p class="text-slate-500 text-sm mb-6">Parfait pour démarrer et tester l'architecture.</p>
      <div class="mb-6">
        <span class="text-4xl font-extrabold text-slate-900">29€</span>
        <span class="text-slate-500 font-medium">/mois</span>
      </div>
      <ul class="space-y-4 mb-8 text-sm text-slate-600">
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Site vitrine statique
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Hébergement inclus
        </li>
        <li class="flex items-center gap-3 opacity-50">
          <svg class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          Blog complet (Astro Collections)
        </li>
      </ul>
      <button class="w-full rounded-xl bg-slate-100 text-slate-900 font-semibold py-3 hover:bg-slate-200 transition-colors">Choisir ce plan</button>
    </div>
    
    <!-- Pro Plan (Mise en avant) -->
    <div class="bg-indigo-600 p-8 rounded-3xl border border-indigo-600 shadow-xl shadow-indigo-600/20 transform md:-translate-y-4 relative">
      <div class="absolute top-0 right-6 transform -translate-y-1/2">
        <span class="bg-indigo-300 text-indigo-900 text-xs font-bold uppercase tracking-wider py-1 px-3 rounded-full">Recommandé</span>
      </div>
      <h3 class="text-lg font-semibold text-white mb-2">Professionnel</h3>
      <p class="text-indigo-200 text-sm mb-6">L'architecture complète avec le moteur de blog.</p>
      <div class="mb-6 text-white">
        <span class="text-4xl font-extrabold">79€</span>
        <span class="text-indigo-200 font-medium">/mois</span>
      </div>
      <ul class="space-y-4 mb-8 text-sm text-indigo-100">
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Tout le plan Essentiel
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Blog Markdown hyper-rapide
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Support prioritaire 24/7
        </li>
      </ul>
      <button class="w-full rounded-xl bg-white text-indigo-600 font-bold py-3 hover:bg-indigo-50 transition-colors shadow-sm">Choisir ce plan</button>
    </div>
    
    <!-- Enterprise Plan -->
    <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm">
      <h3 class="text-lg font-semibold text-slate-900 mb-2">Entreprise</h3>
      <p class="text-slate-500 text-sm mb-6">Pour les projets sur-mesure et à fort trafic.</p>
      <div class="mb-6">
        <span class="text-4xl font-extrabold text-slate-900">Sur devis</span>
      </div>
      <ul class="space-y-4 mb-8 text-sm text-slate-600">
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Architecture API headless
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Intégration d'un CMS tiers
        </li>
        <li class="flex items-center gap-3">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Développement de composants
        </li>
      </ul>
      <button class="w-full rounded-xl bg-slate-100 text-slate-900 font-semibold py-3 hover:bg-slate-200 transition-colors">Contacter les ventes</button>
    </div>
  </div>
</section>
