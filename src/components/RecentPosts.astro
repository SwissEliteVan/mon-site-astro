---
import { getCollection } from 'astro:content';

// Récupérer et trier les articles du plus récent au plus ancien
const allPosts = await getCollection('blog');
const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 rounded-t-3xl border-t border-slate-200">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-12 gap-4">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 tracking-tight">Derniers articles</h2>
      <p class="mt-2 text-slate-600">Restez informé de nos dernières actualités et astuces.</p>
    </div>
    <a href="/blog" class="hidden sm:inline-flex items-center font-medium text-indigo-600 hover:text-indigo-500 transition-colors">
      Voir tout le blog <span aria-hidden="true" class="ml-1">&rarr;</span>
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {recentPosts.map((post) => (
      <article class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl hover:shadow-indigo-500/10 transition-all duration-300 transform hover:-translate-y-1 group flex flex-col relative">
        <div class="h-48 bg-slate-200 relative overflow-hidden">
          {/* Si pas d'image, on affiche un dégradé par défaut */}
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-500 to-purple-600 opacity-90 group-hover:scale-110 transition-transform duration-700"></div>
          <div class="absolute bottom-4 left-4 z-10">
            <span class="bg-white/95 backdrop-blur-sm px-3 py-1 text-xs font-bold text-indigo-700 uppercase tracking-wider rounded-full shadow-sm">
              {post.data.tags?.[0] || 'Général'}
            </span>
          </div>
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <div class="flex items-center text-xs text-slate-500 mb-4 font-medium uppercase tracking-wide">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('fr-FR', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-indigo-600 transition-colors leading-tight">
            <a href={`/blog/${post.slug}`}>
              <span class="absolute inset-0 z-20"></span>
              {post.data.title}
            </a>
          </h3>
          <p class="text-slate-600 line-clamp-3 text-sm flex-grow leading-relaxed">
            {post.data.description}
          </p>
          <div class="mt-4 flex items-center text-indigo-600 text-sm font-semibold group-hover:translate-x-1 transition-transform duration-300">
            Lire l'article <span aria-hidden="true" class="ml-1">&rarr;</span>
          </div>
        </div>
      </article>
    ))}
  </div>
  
  <div class="mt-10 text-center sm:hidden">
    <a href="/blog" class="inline-flex justify-center w-full rounded-xl bg-slate-50 px-8 py-3.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-200 hover:bg-slate-100 transition-colors">
      Voir tout le blog
    </a>
  </div>
</section>
