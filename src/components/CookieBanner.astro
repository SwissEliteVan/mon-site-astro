---
// Composant CookieBanner.astro pour la conformité nLPD
---

<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[100] transform translate-y-full transition-transform duration-700 ease-out sm:bottom-6 sm:left-6 sm:right-auto sm:max-w-sm" aria-hidden="true">
  <div class="bg-[#191A23] text-white rounded-t-3xl sm:rounded-3xl p-6 shadow-2xl border border-white/10 relative overflow-hidden">
    <div class="absolute -top-10 -right-10 w-32 h-32 bg-[#B9FF66] rounded-full blur-3xl opacity-10 pointer-events-none"></div>
    
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="bg-[#1f202b] p-2 rounded-full">
          <svg class="w-5 h-5 text-[#B9FF66]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h3 class="font-bold text-lg tracking-tight text-white">Respect de votre vie privée</h3>
      </div>
      <p class="text-gray-400 text-sm leading-relaxed mb-6">
        Conformément à la nLPD suisse, nous utilisons des cookies pour assurer le bon fonctionnement du site et analyser notre trafic. 
        <a href="/mentions-legales" class="text-[#B9FF66] hover:text-[#A0E655] underline underline-offset-4 transition-colors font-medium">En savoir plus</a>.
      </p>
      
      <div class="flex flex-row gap-3">
        <button id="accept-cookies" class="flex-1 bg-[#B9FF66] hover:bg-[#A0E655] text-black text-sm font-bold py-3 px-4 rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-[#B9FF66] shadow-lg shadow-[#B9FF66]/20 active:scale-95 transform">
          Accepter
        </button>
        <button id="reject-cookies" class="flex-1 bg-[#1f202b] hover:bg-[#2a2b38] text-gray-400 text-sm font-bold py-3 px-4 rounded-xl border border-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-white/20 active:scale-95 transform">
          Refuser
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('accept-cookies');
    const rejectBtn = document.getElementById('reject-cookies');

    if (!localStorage.getItem('clicom_cookie_consent')) {
      setTimeout(() => {
        if (banner) {
          banner.classList.remove('translate-y-full');
          banner.setAttribute('aria-hidden', 'false');
        }
      }, 800);
    }

    const hideBanner = (consentValue) => {
      localStorage.setItem('clicom_cookie_consent', consentValue);
      if (banner) {
        banner.classList.add('translate-y-full');
        setTimeout(() => {
          banner.style.display = 'none';
        }, 700);
      }
    };

    if (acceptBtn) {
      acceptBtn.addEventListener('click', () => hideBanner('accepted'));
    }

    if (rejectBtn) {
      rejectBtn.addEventListener('click', () => hideBanner('rejected'));
    }
  });
</script>