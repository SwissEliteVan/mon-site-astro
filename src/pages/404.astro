---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Erreur 404 - Page introuvable | CLICOM";
const pageDescription = "Désolé, la page que vous recherchez n'existe pas ou a été déplacée.";
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4 sm:px-6 lg:px-8 py-20 relative overflow-hidden">
    <div class="relative w-full max-w-xl mx-auto">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 md:w-96 md:h-96 bg-[#B9FF66] rounded-full blur-[100px] opacity-10 pointer-events-none"></div>
      
      <h1 class="relative text-7xl md:text-9xl font-extrabold text-[#B9FF66] tracking-tight mb-4">
        404
      </h1>
      
      <p class="relative text-xl md:text-2xl text-white font-semibold mb-4">
        Oups ! Page introuvable.
      </p>
      
      <p class="relative text-gray-400 mb-8 max-w-md mx-auto">
        La page que vous cherchez a peut-être été renommée, supprimée, ou n'a jamais existé.
      </p>
      
      <div class="relative">
        <a 
          href="/" 
          class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-[#191A23] bg-[#B9FF66] rounded-full hover:scale-105 hover:bg-white transition-all duration-300"
        >
          Retour à l'accueil
        </a>
      </div>
    </div>
  </div>
</Layout>