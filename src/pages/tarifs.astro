---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ui/ContactForm.astro';

const plans = [
  {
    name: "Starter",
    tag: "Site vitrine",
    price: "3 000",
    unit: "CHF",
    note: "Paiement unique — pas d'abonnement",
    highlight: false,
    features: [
      "Site 5 pages sur-mesure",
      "Chargement en moins de 1 seconde",
      "Design adapté à votre activité",
      "Textes de vente rédigés par CLICOM",
      "Formulaire de contact conforme nLPD",
      "Hébergement année 1 inclus",
      "Formation utilisation (1h)",
      "Livraison en 21 jours",
    ],
    cta: "Demander ce forfait",
  },
  {
    name: "Pro",
    tag: "Site + Visibilité",
    price: "5 500",
    unit: "CHF + 1 000/mois",
    note: "Site livré en 21j · Visibilité dès le 1er mois",
    highlight: true,
    features: [
      "Tout le forfait Starter",
      "Optimisation Google Maps complète",
      "Stratégie d'avis clients (plaquette NFC)",
      "Rapport mensuel appels & visites",
      "Publication hebdomadaire sur votre fiche",
      "Réponse aux avis en votre nom",
      "Suivi de positionnement local mensuel",
      "Accès direct à Mohamed Saber",
    ],
    cta: "Demander ce forfait",
  },
  {
    name: "Full",
    tag: "Site + Visibilité + Pub",
    price: "Sur devis",
    unit: "",
    note: "À partir de 2 000 CHF/mois · Budget media séparé",
    highlight: false,
    features: [
      "Tout le forfait Pro",
      "Campagnes Google Ads gérées",
      "Page de destination dédiée incluse",
      "Suivi des appels par source",
      "Rapport mensuel coût par appel",
      "Optimisation hebdomadaire des campagnes",
      "Fidélisation SMS automatisée",
      "Conformité nLPD complète incluse",
    ],
    cta: "Demander un devis",
  },
];
---

<Layout
  title="Tarifs Marketing Digital PME Suisse | CLICOM — Prix Transparents"
  description="Découvrez les forfaits CLICOM pour les PME de Suisse romande. Sites web, visibilité Google Maps, publicité en ligne. Prix clairs, sans surprise."
>

  <!-- ── HERO ───────────────────────────────────────── -->
  <section class="page-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="hero-badge">Zéro frais cachés · Devis en 24h</span>
      <h1 class="hero-title">Des investissements transparents,<br/>un retour mesurable.</h1>
      <p class="hero-text">Fini les devis opaques des agences traditionnelles. Grâce à l'efficacité de nos agents IA, nous vous proposons des prestations haut de gamme à des tarifs justes et maîtrisés.</p>
      <div class="hero-actions">
        <a href="#contact" class="btn-lime">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Demander un devis gratuit
        </a>
        <a href="#plans" class="btn-outline">Voir les forfaits ↓</a>
      </div>
    </div>
  </section>

  <!-- ── ENGAGEMENT TARIFS ─────────────────────────── -->
  <section class="warning-band">
    <div class="warning-inner">
      <p class="warning-text">En dessous de <strong>1 000 CHF/mois</strong>, votre entreprise reste invisible en Suisse romande. Ce n'est pas notre règle — c'est la réalité du marché publicitaire local.</p>
    </div>
  </section>

  <!-- ── PLANS ──────────────────────────────────────── -->
  <section id="plans" class="plans-section">
    <div class="section-inner">
      <div class="section-header centered">
        <span class="section-label">Nos forfaits</span>
        <h2 class="section-title">Choisissez votre niveau d'engagement.</h2>
        <p class="section-sub">Chaque forfait est un investissement — pas une dépense. Vous payez pour des résultats mesurables, pas pour des heures de réunion.</p>
      </div>

      <div class="plans-grid">
        {plans.map(plan => (
          <div class={`plan-card ${plan.highlight ? 'plan-highlight' : ''}`}>
            {plan.highlight && <div class="plan-popular">Le plus choisi</div>}
            <div class="plan-header">
              <p class="plan-tag">{plan.tag}</p>
              <p class="plan-name">{plan.name}</p>
              <div class="plan-price">
                <span class="price-amount">{plan.price}</span>
                {plan.unit && <span class="price-unit"> {plan.unit}</span>}
              </div>
              <p class="plan-note">{plan.note}</p>
            </div>
            <ul class="plan-features">
              {plan.features.map(f => (
                <li class="plan-feature">
                  <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="#contact" class={`plan-cta ${plan.highlight ? 'plan-cta-primary' : 'plan-cta-ghost'}`}>{plan.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ PRIX ───────────────────────────────────── -->
  <section class="faq-section">
    <div class="section-inner">
      <div class="section-header centered">
        <span class="section-label">Questions sur les tarifs</span>
        <h2 class="section-title">Ce que vous avez le droit de savoir.</h2>
      </div>
      <div class="faq-grid">
        {[
          { q: "Pourquoi vos sites coûtent moins cher que la plupart des agences ?", a: "Parce que nos agents IA (Lumina, Koda, Synergia) produisent en quelques heures ce qu'une agence classique produit en semaines. Nous répercutons ce gain d'efficacité sur votre facture — pas sur nos marges." },
          { q: "Y a-t-il des frais cachés après la livraison ?", a: "Non. Le prix annoncé inclut l'hébergement la première année, la formation et la conformité nLPD. À partir de l'an 2, l'hébergement seul est facturé (environ 200 CHF/an). Rien d'autre." },
          { q: "Puis-je commencer par un site seul, sans l'abonnement ?", a: "Oui. Le forfait Starter est un paiement unique. Vous pouvez ajouter la visibilité et la publicité plus tard, sans recommencer de zéro." },
          { q: "Le budget publicité est-il inclus dans vos honoraires ?", a: "Non. Vos budgets publicitaires (Google Ads) sont versés directement par vous à Google. Nous gérons vos campagnes, nous ne touchons pas votre budget media." },
        ].map(faq => (
          <div class="faq-item">
            <h3 class="faq-q">{faq.q}</h3>
            <p class="faq-a">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CONTACT ───────────────────────────────────── -->
  <ContactForm
    title="Quel forfait correspond à votre situation ?"
    subtitle="Décrivez votre activité et votre budget estimé. Mohamed Saber vous propose la combinaison optimale sous 24h."
  />

</Layout>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background-color: var(--color-brand-dark);
    padding: 7rem 1.5rem 5rem;
    text-align: center;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(185,255,102,0.09) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1; max-width: 52rem; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 1.5rem;
  }
  .hero-badge {
    display: inline-block;
    background-color: var(--color-brand-lime-muted);
    border: 1px solid var(--color-border-lime);
    color: var(--color-brand-lime);
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em;
    padding: 0.35rem 1rem; border-radius: var(--radius-full);
  }
  .hero-title { font-size: var(--text-hero); font-weight: 900; color: #fff; line-height: 1.12; letter-spacing: -0.03em; }
  .hero-text { font-size: 1.125rem; color: #9ca3af; line-height: 1.7; max-width: 40rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 0.5rem; }
  .btn-lime {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background-color: var(--color-brand-lime); color: var(--color-brand-dark);
    font-weight: 800; font-size: 1rem; padding: 0.875rem 1.75rem;
    border-radius: var(--radius-xl); text-decoration: none;
    transition: var(--transition-base); box-shadow: var(--shadow-lime);
  }
  .btn-lime:hover { background-color: var(--color-brand-lime-hover); transform: translateY(-2px); }
  .btn-outline {
    display: inline-flex; align-items: center;
    color: #9ca3af; font-weight: 600; font-size: 0.9375rem;
    padding: 0.875rem 1.5rem; border-radius: var(--radius-xl);
    border: 1px solid var(--color-border); text-decoration: none; transition: var(--transition-base);
  }
  .btn-outline:hover { color: #fff; border-color: var(--color-border-strong); }

  /* Warning */
  .warning-band { background-color: rgba(185,255,102,0.06); border-top: 1px solid var(--color-border-lime); border-bottom: 1px solid var(--color-border-lime); padding: 1.25rem 1.5rem; }
  .warning-inner { max-width: 52rem; margin: 0 auto; text-align: center; }
  .warning-text { font-size: 0.9375rem; color: #9ca3af; line-height: 1.6; }
  .warning-text strong { color: var(--color-brand-lime); }

  /* Plans */
  .plans-section { padding: 5rem 1.5rem; background-color: var(--color-brand-dark); }
  .section-inner { max-width: 72rem; margin: 0 auto; }
  .section-header { margin-bottom: 3rem; }
  .section-header.centered { text-align: center; }
  .section-title { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; color: #fff; line-height: 1.2; margin-top: 0.5rem; }
  .section-sub { font-size: 1rem; color: #6b7280; margin-top: 0.75rem; max-width: 44rem; margin-inline: auto; }

  .plans-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr)); gap: 1.5rem; align-items: start; }

  .plan-card {
    background-color: var(--color-brand-dark-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-3xl);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    transition: border-color 0.2s;
  }
  .plan-card:hover { border-color: var(--color-border-lime); }
  .plan-highlight {
    border-color: var(--color-brand-lime);
    box-shadow: var(--shadow-lime);
  }

  .plan-popular {
    position: absolute;
    top: -0.875rem;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-brand-lime);
    color: var(--color-brand-dark);
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.875rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .plan-tag { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-brand-lime); margin-bottom: 0.25rem; }
  .plan-name { font-size: 1.375rem; font-weight: 900; color: #fff; margin-bottom: 0.75rem; }
  .plan-price { display: flex; align-items: baseline; gap: 0.25rem; flex-wrap: wrap; }
  .price-amount { font-size: 2.25rem; font-weight: 900; color: #fff; line-height: 1; letter-spacing: -0.03em; }
  .price-unit { font-size: 0.875rem; color: #6b7280; font-weight: 500; }
  .plan-note { font-size: 0.75rem; color: #4b5563; margin-top: 0.375rem; }

  .plan-features { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; flex: 1; }
  .plan-feature { display: flex; align-items: flex-start; gap: 0.625rem; font-size: 0.875rem; color: #d1d5db; line-height: 1.5; }
  .plan-feature svg { color: var(--color-brand-lime); flex-shrink: 0; margin-top: 0.2rem; }

  .plan-cta {
    display: block;
    text-align: center;
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: var(--transition-base);
  }
  .plan-cta-primary { background-color: var(--color-brand-lime); color: var(--color-brand-dark); }
  .plan-cta-primary:hover { background-color: var(--color-brand-lime-hover); transform: translateY(-1px); }
  .plan-cta-ghost { border: 1px solid var(--color-border); color: #9ca3af; }
  .plan-cta-ghost:hover { border-color: var(--color-border-strong); color: #fff; }

  /* FAQ */
  .faq-section { padding: 5rem 1.5rem; background-color: var(--color-brand-dark-2); border-top: 1px solid var(--color-border); }
  .faq-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(22rem, 1fr)); gap: 1.5rem; }
  .faq-item { background-color: var(--color-brand-dark); border: 1px solid var(--color-border); border-radius: var(--radius-2xl); padding: 1.75rem; }
  .faq-q { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 0.75rem; line-height: 1.4; }
  .faq-a { font-size: 0.875rem; color: #6b7280; line-height: 1.7; }
</style>
