---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';

export function getStaticPaths() {
  return [
    {
      params: { ville: 'lausanne' },
      props: {
        nom: 'Lausanne',
        canton: 'Vaud',
        description: 'Agence marketing digital à Lausanne — CLICOM booste la visibilité des PME lausannoises sur Google Maps et Google Ads.',
        population: '140 000',
        intro: 'Capitale vaudoise et hub économique romand, Lausanne concentre une concurrence digitale féroce. Chaque jour, des centaines de PME lausannoises perdent des clients faute de visibilité en ligne.',
        quartiers: 'Ouchy, Flon, Pully, Renens, Prilly, Écublens',
        stat: '2 300+ PME actives à Lausanne',
      }
    },
    {
      params: { ville: 'vevey' },
      props: {
        nom: 'Vevey',
        canton: 'Vaud',
        description: 'Agence marketing digital à Vevey — CLICOM aide les PME de la Riviera vaudoise à dominer Google Maps et attirer de nouveaux clients.',
        population: '20 000',
        intro: 'Vevey et la Riviera vaudoise accueillent des centaines de commerces, artisans et indépendants. Dans cette zone touristique et résidentielle, apparaître en premier sur Google Maps est la différence entre un téléphone qui sonne et un agenda vide.',
        quartiers: 'Vevey, La Tour-de-Peilz, Corseaux, Chardonne, Blonay',
        stat: '800+ PME actives sur la Riviera vaudoise',
      }
    },
    {
      params: { ville: 'montreux' },
      props: {
        nom: 'Montreux',
        canton: 'Vaud',
        description: 'Agence marketing digital à Montreux — CLICOM optimise la visibilité Google des hôtels, restaurants et commerces de Montreux.',
        population: '26 000',
        intro: 'Montreux attire des visiteurs du monde entier. Pour les commerces, hôtels et restaurants locaux, être visible sur Google Maps n\'est pas un luxe — c\'est une condition de survie dans une ville aussi touristique.',
        quartiers: 'Montreux, Clarens, Veytaux, Villeneuve, Territet',
        stat: '600+ établissements touristiques et commerces',
      }
    },
    {
      params: { ville: 'geneve' },
      props: {
        nom: 'Genève',
        canton: 'Genève',
        description: 'Agence marketing digital à Genève — CLICOM propulse les PME genevoises en tête de Google Maps et Google Ads.',
        population: '200 000',
        intro: 'Genève est le marché le plus compétitif de Suisse romande. Les PME genevoises font face à une concurrence internationale. Sans une stratégie digitale précise, votre entreprise reste invisible dans une ville de 200 000 habitants.',
        quartiers: 'Eaux-Vives, Carouge, Plainpalais, Champel, Meyrin, Lancy',
        stat: '5 000+ PME actives à Genève',
      }
    },
    {
      params: { ville: 'fribourg' },
      props: {
        nom: 'Fribourg',
        canton: 'Fribourg',
        description: 'Agence marketing digital à Fribourg — CLICOM développe la visibilité digitale des PME fribourgeoises bilingues.',
        population: '38 000',
        intro: 'Fribourg, ville bilingue au carrefour des cultures, offre un marché local unique. Les PME fribourgeoises ont besoin d\'une stratégie digitale qui parle à la fois aux francophones et aux germanophones de la région.',
        quartiers: 'Bourg, Pérolles, Villars-sur-Glâne, Givisiez, Marly',
        stat: '1 200+ PME actives à Fribourg',
      }
    },
  ];
}

const { ville } = Astro.params;
const { nom, canton, description, population, intro, quartiers, stat } = Astro.props;
---

<Layout
  title={`Agence Marketing Digital ${nom} | CLICOM — PME ${canton}`}
  description={description}
>

  <!-- ── HERO ───────────────────────────────────────── -->
  <section class="page-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="hero-badge">{nom} · {canton} · Suisse romande</span>
      <h1 class="hero-title">Votre PME à <span class="text-lime">{nom}</span><br/>mérite d'être trouvée.</h1>
      <p class="hero-text">{intro}</p>
      <div class="hero-actions">
        <a href="#contact" class="btn-lime">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Audit gratuit pour {nom}
        </a>
        <a href="/tarifs" class="btn-outline">Voir les forfaits →</a>
      </div>
    </div>
  </section>

  <!-- ── STATS LOCALES ─────────────────────────────── -->
  <section class="stats-band">
    <div class="stat-wrap">
      <span class="stat-n">{population}</span>
      <span class="stat-l">habitants<br/>à {nom}</span>
    </div>
    <div class="stat-div" aria-hidden="true"></div>
    <div class="stat-wrap">
      <span class="stat-n">73 %</span>
      <span class="stat-l">cherchent sur Maps<br/>avant de venir</span>
    </div>
    <div class="stat-div" aria-hidden="true"></div>
    <div class="stat-wrap">
      <span class="stat-n">Top 3</span>
      <span class="stat-l">résultats captent<br/>87 % des clics</span>
    </div>
    <div class="stat-div" aria-hidden="true"></div>
    <div class="stat-wrap">
      <span class="stat-n">{stat.split('+')[0]}+</span>
      <span class="stat-l">PME concurrentes<br/>à {nom}</span>
    </div>
  </section>

  <!-- ── SERVICES LOCAUX ───────────────────────────── -->
  <section class="content-section">
    <div class="section-inner">
      <div class="section-header centered">
        <span class="section-label">Nos services à {nom}</span>
        <h2 class="section-title">Ce que nous faisons pour<br/>les PME de {nom}.</h2>
        <p class="section-sub">Des solutions concrètes, adaptées au marché local de {nom} et de sa région ({quartiers}).</p>
      </div>
      <div class="services-grid">
        {[
          {
            icon: `<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
            title: `Visibilité Google Maps ${nom}`,
            text: `Apparaissez dans le top 3 des recherches "votre métier + ${nom}". Vos clients vous trouvent avant vos concurrents.`
          },
          {
            icon: `<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>`,
            title: `Site web ultra-rapide`,
            text: `Un site livré en 21 jours, chargement en moins d'1 seconde, optimisé pour les recherches locales à ${nom}.`
          },
          {
            icon: `<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>`,
            title: `Google Ads ${nom}`,
            text: `Campagnes publicitaires ciblées sur ${nom} et ses environs (${quartiers}). Téléphone qui sonne dès le 1er jour.`
          },
          {
            icon: `<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
            title: `Conformité nLPD`,
            text: `Votre site et vos communications respectent la loi fédérale suisse. Zéro risque d'amende jusqu'à 250 000 CHF.`
          },
        ].map(s => (
          <div class="service-card">
            <div class="service-icon" set:html={s.icon}></div>
            <h3 class="service-title">{s.title}</h3>
            <p class="service-text">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ZONE COUVERTE ─────────────────────────────── -->
  <section class="zone-section">
    <div class="section-inner">
      <div class="zone-box">
        <div class="zone-left">
          <span class="section-label">Zone d'intervention</span>
          <h2 class="section-title">Nous intervenons à {nom}<br/>et dans toute la région.</h2>
          <p class="body-text">Notre équipe couvre {nom} et ses environs : {quartiers}. Peu importe votre localisation précise dans la région, nous optimisons votre visibilité pour que vos clients locaux vous trouvent.</p>
        </div>
        <div class="zone-right">
          <div class="zone-tag-grid">
            {quartiers.split(', ').map(q => (
              <span class="zone-tag">{q}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SCHEMA LD+JSON LOCAL ──────────────────────── -->
  <script type="application/ld+json" set:text={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": `CLICOM — Agence Marketing Digital ${nom}`,
    "url": `https://clicom.ch/${ville}`,
    "telephone": "+41000000000",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": nom,
      "addressRegion": canton,
      "addressCountry": "CH"
    },
    "areaServed": {
      "@type": "City",
      "name": nom
    },
    "description": description,
  })} />

  <!-- ── CONTACT ───────────────────────────────────── -->
  <ContactForm
    title={`Votre audit de visibilité gratuit à ${nom}`}
    subtitle={`Décrivez votre activité à ${nom}. Mohamed Saber analyse votre marché local et vous rappelle sous 2h avec un plan d'action concret.`}
  />

</Layout>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background-color: var(--color-brand-dark);
    padding: 7rem 1.5rem 5rem;
    text-align: center;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(185,255,102,0.09) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1; max-width: 52rem; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 1.5rem;
  }
  .hero-badge {
    display: inline-block;
    background-color: var(--color-brand-lime-muted);
    border: 1px solid var(--color-border-lime);
    color: var(--color-brand-lime);
    font-size: 0.75rem; font-weight: