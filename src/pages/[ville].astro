        <span class="text-lime-400 font-bold">{geoData.stat}</span> : {geoData.statDesc}
      </p>
    </div>
  </section>

  <!-- Section Services -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-gray-900 mb-12">Nos solutions pour {nomVille}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {services.map((service) => (
          <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="text-xl font-bold text-gray-900 mb-2">{service.titre}</h3>
            <p class="text-gray-600 text-sm">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
