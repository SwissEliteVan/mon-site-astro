    <video autoplay loop muted playsinline poster={geoData.imageHero} class="absolute inset-0 w-full h-full object-cover opacity-40">
      <source src="/assets/videos/hero.mp4" type="video/mp4" />
    </video>
    
    <!-- Contenu dynamique par-dessus la vidéo -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumb />
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl mt-8">
        {geoData.accroche}
      </h1>
