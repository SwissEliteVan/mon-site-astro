---
import Layout from '../layouts/Layout.astro';

// Génération dynamique de toutes les pages villes existantes
export function getStaticPaths() {
  const villesData = {
    lausanne: { cp: "1000", lat: 46.519653, lng: 6.632273 },
    geneve: { cp: "1200", lat: 46.204391, lng: 6.143158 },
    vevey: { cp: "1800", lat: 46.462803, lng: 6.843058 },
    montreux: { cp: "1820", lat: 46.431221, lng: 6.910680 },
    nyon: { cp: "1260", lat: 46.383268, lng: 6.234796 },
    yverdon: { cp: "1400", lat: 46.778474, lng: 6.641183 },
    fribourg: { cp: "1700", lat: 46.806477, lng: 7.161972 },
    neuchatel: { cp: "2000", lat: 46.989587, lng: 6.929264 },
    sion: { cp: "1950", lat: 46.233122, lng: 7.360626 },
    martigny: { cp: "1920", lat: 46.103117, lng: 7.072736 },
    renens: { cp: "1020", lat: 46.539722, lng: 6.587500 },
    pully: { cp: "1009", lat: 46.510000, lng: 6.661944 }
  };

  return Object.keys(villesData).map(ville => ({
    params: { ville },
    props: { 
      nomVille: ville.charAt(0).toUpperCase() + ville.slice(1),
      geoData: villesData[ville]
    },
  }));
}

const { ville } = Astro.params;
const { nomVille, geoData } = Astro.props;

// Création du schéma JSON-LD
const schemaLD = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": `CLICOM - Agence Web à ${nomVille}`,
  "description": `Agence web spécialisée dans la création de sites internet et le référencement local (SEO) pour les PME de ${nomVille} et environs.`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": nomVille,
    "postalCode": geoData.cp,
    "addressCountry": "CH"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": geoData.lat,
    "longitude": geoData.lng
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  ],
  "telephone": "+41234567890",
  "url": `https://clicom.pro/${ville}`,
  "priceRange": "$$",
  "image": "https://clicom.pro/logo.png"
};
---

<Layout 
  title={`Création de site internet et SEO à ${nomVille} | CLICOM`} 
  description={`Agence web experte en création de site internet et référencement local (SEO) à ${nomVille}. Attirez plus de clients dans votre région.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLD)} />
  <section class="pt-32 pb-24 bg-[#191A23] min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <a href="/" class="inline-flex items-center text-gray-400 hover:text-[#B9FF66] transition-colors mb-12">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Retour à l'accueil
      </a>

      <div class="text-center mb-16">
        <span class="text-[#B9FF66] font-bold tracking-wider uppercase text-sm mb-4 block">Expertise Locale</span>
        <h1 class="text-[clamp(2.5rem,4vw,4rem)] font-bold text-white mb-6 leading-tight">
          Création de site internet et SEO à {nomVille}
        </h1>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto">
          Propulsez votre PME sur internet. Nous aidons les entreprises de {nomVille} et ses environs à dominer les résultats de recherche Google.
        </p>
      </div>

      <div class="w-full h-64 md:h-96 rounded-3xl overflow-hidden mb-16 shadow-2xl border border-white/5">
      <img src="/assets/images/clicom-agence-web-suisse-romande.webp" alt={`Visibilité digitale et SEO à ${nomVille}`} class="w-full h-full object-cover" />
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center mb-24">
        <div>
          <h2 class="text-3xl font-bold text-white mb-6">L'importance de la visibilité locale pour les PME</h2>
          <p class="text-gray-400 text-lg mb-6 leading-relaxed">
            À {nomVille}, la grande majorité des consommateurs cherchent un artisan ou un commerce de proximité sur Google avant de se déplacer. Si votre entreprise n'apparaît pas dans les premiers résultats ou sur Google Maps, vous laissez le champ libre à vos concurrents.
          </p>
          <p class="text-gray-400 text-lg leading-relaxed">
            Avoir un site web performant, rapide et optimisé pour le référencement local (SEO) n'est plus une option, c'est le moteur de votre croissance.
          </p>
        </div>
        <div class="bg-[#1f202b] p-8 md:p-10 rounded-3xl border border-white/10 shadow-2xl">
          <h3 class="text-2xl font-bold text-white mb-4">Passez à l'action dès aujourd'hui</h3>
          <p class="text-gray-400 mb-8">Découvrez exactement combien de clients vous perdez chaque mois à {nomVille} et comment inverser la tendance.</p>
          <a href="/#contact" class="block text-center w-full bg-[#B9FF66] text-[#191A23] font-bold px-8 py-4 rounded-xl hover:bg-[#a3e655] transition-all text-lg shadow-lg shadow-[#B9FF66]/20">
            Réserver mon audit gratuit
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>