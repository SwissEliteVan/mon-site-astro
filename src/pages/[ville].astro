<Layout title={pageTitle} description={pageDescription} image={pageImage} canonical={pageCanonical}>

  <!-- Section Hero avec Vidéo -->
  <section class="relative w-full h-[80vh] flex flex-col items-center justify-center overflow-hidden bg-gray-900">
