                {[
                  { data: 'Nom et prénom', purpose: 'Vous identifier et personnaliser notre réponse', basis: 'Consentement (art. 6 nLPD)' },
                  { data: 'Adresse email', purpose: 'Vous recontacter suite à votre demande', basis: 'Consentement (art. 6 nLPD)' },
                  { data: 'URL de votre site', purpose: 'Préparer un audit de votre visibilité en ligne', basis: 'Intérêt légitime (art. 31 nLPD)' },
