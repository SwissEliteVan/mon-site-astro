import Layout from '../layouts/Layout.astro';
const lastUpdate = new Date().toLocaleDateString('fr-CH', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Politique de confidentialité (nLPD) | CLICOM"
  description="Politique de confidentialité de CLICOM, conforme à la nouvelle Loi fédérale suisse sur la protection des données (nLPD — RS 235.1). Vos droits, nos engagements.">

  <section class="pt-32 pb-24 bg-[#191A23] min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <a href="/" class="inline-flex items-center text-gray-400 hover:text-[#B9FF66] transition-colors mb-12">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Retour à l'accueil
      </a>

      <!-- En-tête -->
      <div class="mb-16">
        <div class="inline-flex items-center gap-2 bg-[#B9FF66]/10 border border-[#B9FF66]/20 text-[#B9FF66] text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Conforme nLPD — RS 235.1
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Politique de confidentialité</h1>
        <p class="text-gray-400 text-lg leading-relaxed max-w-2xl">
          Chez CLICOM, la protection de vos informations personnelles est une priorité absolue. Ce document vous explique, sans jargon, ce que nous faisons avec vos données et quels sont vos droits.
        </p>
        <p class="text-gray-600 text-sm mt-4">Dernière mise à jour : {lastUpdate}</p>
      </div>

      <!-- Résumé visuel -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        <div class="bg-[#1f202b] p-4 rounded-2xl border border-white/5 text-center">
          <div class="text-2xl mb-2" aria-hidden="true">🚫</div>
          <p class="text-white text-xs font-bold">Zéro revente</p>
          <p class="text-gray-600 text-xs mt-1">de vos données</p>
        </div>
        <div class="bg-[#1f202b] p-4 rounded-2xl border border-white/5 text-center">
          <div class="text-2xl mb-2" aria-hidden="true">🇨🇭</div>
          <p class="text-white text-xs font-bold">Droit suisse</p>
          <p class="text-gray-600 text-xs mt-1">nLPD applicable</p>
        </div>
        <div class="bg-[#1f202b] p-4 rounded-2xl border border-white/5 text-center">
          <div class="text-2xl mb-2" aria-hidden="true">🔒</div>
          <p class="text-white text-xs font-bold">HTTPS</p>
          <p class="text-gray-600 text-xs mt-1">Chiffrement total</p>
        </div>
        <div class="bg-[#1f202b] p-4 rounded-2xl border border-white/5 text-center">
          <div class="text-2xl mb-2" aria-hidden="true">⏱</div>
          <p class="text-white text-xs font-bold">30 jours</p>
          <p class="text-gray-600 text-xs mt-1">pour vous répondre</p>
        </div>
      </div>

      <div class="space-y-6">

        <!-- 1. Responsable du traitement -->
        <div class="bg-[#1f202b] rounded-3xl border border-white/10 overflow-hidden">
          <div class="px-8 py-5 border-b border-white/5">
            <h2 class="text-lg font-bold text-white flex items-center gap-3">
              <span class="w-7 h-7 bg-[#B9FF66]/10 text-[#B9FF66] rounded-lg flex items-center justify-center text-sm font-black flex-shrink-0">1</span>
              Responsable du traitement des données
            </h2>
          </div>
          <div class="px-8 py-6 text-gray-400 text-sm leading-relaxed space-y-3">
            <p>Le responsable du traitement des données personnelles collectées via ce site est :</p>
            <div class="bg-[#191A23] rounded-2xl p-5 border border-white/5 text-sm space-y-1">
              <p><span class="text-gray-500">Entreprise :</span> <strong class="text-white">CLICOM</strong></p>
              <p><span class="text-gray-500">Responsable :</span> <strong class="text-white">Mohamed Saber</strong></p>
              <p><span class="text-gray-500">Adresse :</span> <strong class="text-white">Corseaux, Canton de Vaud, Suisse</strong></p>
              <p><span class="text-gray-500">Email :</span> <a href="mailto:contact@clicom.ch" class="text-[#B9FF66] hover:underline font-bold">contact@clicom.ch</a></p>
            </div>
            <p>Conformément à l'art. 5 lit. j nLPD, le responsable du traitement est la personne qui, seule ou conjointement avec d'autres, détermine les finalités et les moyens du traitement des données personnelles.</p>
          </div>
        </div>

        <!-- 2. Données collectées -->
        <div class="bg-[#1f202b] rounded-3xl border border-white/10 overflow-hidden">
          <div class="px-8 py-5 border-b border-white/5">
            <h2 class="text-lg font-bold text-white flex items-center gap-3">
              <span class="w-7 h-7 bg-[#B9FF66]/10 text-[#B9FF66] rounded-lg flex items-center justify-center text-sm font-black flex-shrink-0">2</span>
              Quelles données collectons-nous ?
            </h2>
          </div>
          <div class="px-8 py-6 space-y-6">

            <div>
              <h3 class="text-white font-bold mb-3 text-sm uppercase tracking-wider">A. Via le formulaire de contact</h3>
              <div class="space-y-2">
                {[
                  { data: 'Nom et prénom', purpose: 'Vous identifier et personnaliser notre réponse', basis: 'Consentement (art. 6 nLPD)' },
                  { data: 'Adresse email', purpose: 'Vous recontacter suite à votre demande', basis: 'Consentement (art. 6 nLPD)' },
                  { data: 'URL de votre site', purpose: 'Préparer un audit de votre visibilité en ligne', basis: 'Intérêt légitime (art. 31 nLPD)' },
                ].map(item => (
                  <div class="bg-[#191A23] rounded-xl p-4 border border-white/5 text-xs">
                    <div class="flex justify-between items-start gap-4">
                      <div>
                        <p class="text-white font-bold mb-1">{item.data}</p>
                        <p class="text-gray-500">{item.purpose}</p>
                      </div>
                      <span class="bg-[#B9FF66]/10 text-[#B9FF66] px-2 py-1 rounded-lg text-xs font-medium flex-shrink-0 border border-[#B9FF66]/10">{item.basis}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="text-white font-bold mb-3 text-sm uppercase tracking-wider">B. Données de navigation (anonymes)</h3>
              <div class="bg-[#191A23] rounded-xl p-5 border border-white/5 text-sm text-gray-400 space-y-2">
                <p>Lors de votre visite, notre serveur enregistre automatiquement des données techniques <strong class="text-white">totalement anonymes et non personnelles</strong> :</p>
                <ul class="space-y-1 text-xs mt-3">
                  <li class="flex items-center gap-2"><span class="text-[#B9FF66]">→</span> Type de navigateur et système d'exploitation</li>
                  <li class="flex items-center gap-2"><span class="text-[#B9FF66]">→</span> Pages visitées et durée de la visite</li>
                  <li class="flex items-center gap-2"><span class="text-[#B9FF66]">→</span> Pays d'origine (non l'adresse IP précise)</li>
                </ul>
                <p class="text-xs text-gray-600 mt-3 border-t border-white/5 pt-3">Ces données servent uniquement à améliorer le site. Elles ne permettent pas de vous identifier personnellement.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- 3. Ce que nous ne faisons PAS -->
        <div class="bg-[#1f202b] rounded-3xl border border-red-500/10 overflow-hidden">
          <div class="px-8 py-5 border-b border-red-500/10 bg-red-500/5">
            <h2 class="text-lg font-bold text-white flex items-center gap-3">
              <span class="w-7 h-7 bg-red-500/10 text-red-400 rounded-lg flex items-center justify-center text-sm font-black flex-shrink-0">3</span>
              Ce que nous ne faisons <span class="text-red-400">jamais</span> avec vos données
            </h2>
          </div>
          <div class="px-8 py-6">
            <div class="space-y-3">
              {[
                'Vendre, louer ou échanger vos données personnelles avec des tiers',
                'Utiliser vos données à des fins publicitaires pour d\'autres entreprises',
                'Transférer vos données hors de Suisse sans garanties équivalentes',
                'Conserver vos données au-delà de la durée nécessaire',
                'Prendre des décisions automatisées à votre égard sans intervention humaine',
              ].map(item => (
                <div class="flex items-start gap-3 bg-[#191A23] p-4 rounded-xl border border-white/5">
                  <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                  <p class="text-gray-400 text-sm">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 4. Durée de conservation -->
        <div class="bg-[#1f202b] rounded-3xl border border-white/10 overflow-hidden">
          <div class="px-8 py-5 border-b border-white/5">
            <h2 class="text-lg font-bold text-white flex items-center gap-3">
              <span class="w-7 h-7 bg-[#B9FF66]/10 text-[#B9FF66] rounded-lg flex items-center justify-center text-sm font-black flex-shrink-0">4</span>
              Combien de temps gardons-nous vos données ?
            </h2>
          </div>
          <div class="px-8 py-6">
            <div class="space-y-3">
              {[
                { type: 'Données de contact (formulaire)', duration: '12 mois maximum', detail: 'Supprimées après traitement de votre demande, au plus tard 12 mois après votre dernier contact.' },
                { type: 'Données de navigation anonymes', duration: '13 mois', detail: 'Standard suisse pour les statistiques de site, conformément aux recommandations du PFPDT.' },
                { type: 'Correspondance email', duration: '3 ans', detail: 'Durée légale minimale pour les communications professionnelles (art. 958f CO).' },
              ].map(item => (
                <div class="bg-[#191A23] p-5 rounded-xl border border-white/5">
                  <div class="flex justify-between items-start gap-4 mb-2">
                    <p class="text-white font-bold text-sm">{item.type}</p>
                    <span class="bg-[#B9FF66] text-[#191A23] text-xs font-black px-3 py-1 rounded-full flex-shrink-0">{item.duration}</span>
                  </div>
                  <p class="text-gray-500 text-xs">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 5. Sécurité -->
        <div class="bg-[#1f202b] rounded-3xl border border-white/10 overflow-hidden">
          <div class="px-8 py-5 border-b border-white/5">
            <h2 class="text-lg font-bold text-white flex items-center gap-3">
              <span class="w-7 h-7 bg-[#B9FF66]/10 text-[#B9FF66] rounded-lg flex items-center justify-center text-sm font-black flex-shrink-0">5</span>
              Comment sécurisons-nous vos données ?
            </h2>
          </div>
          <div class="px-8 py-6">
            <div class="grid md:grid-cols-2 gap-4">
              {[
                { icon: '🔐', title: 'HTTPS / TLS', desc: 'Toutes les communications entre votre navigateur et notre serveur sont chiffrées.' },
                { icon: '🏗', title: 'Architecture statique', desc: 'Ce site est généré statiquement (Astro SSG). Aucune base de données exposée.' },
                { icon: '🚫', title: 'Zéro cookie traceur', desc: 'Aucun pixel publicitaire, aucun Google Analytics, aucun tracker tiers.' },
                { icon: '👤', title: 'Accès restreint', desc: 'Seul le responsable de l\'agence a accès à vos données personnelles.' },
              ].map(item => (
                <div class="bg-[#191A23] p-5 rounded-xl border border-white/5">
                  <div class="text-2xl mb-3" aria-hidden="true">{item.icon}</div>
