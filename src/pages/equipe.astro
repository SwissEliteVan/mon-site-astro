---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ui/ContactForm.astro';

const agents = [
  {
    name: "Lumina",
    role: "Analyste & Stratège Contenu",
    color: "#B9FF66",
    description: "Lumina analyse votre marché local, vos concurrents et vos données pour produire les contenus les plus pertinents pour votre clientèle cible en Suisse romande.",
    competences: [
      "Analyse de marché local",
      "Rédaction de textes de vente",
      "Stratégie de contenu blog",
      "Optimisation des fiches Google",
    ],
  },
  {
    name: "Koda",
    role: "Développeur & Architecte Technique",
    color: "#60a5fa",
    description: "Koda construit et optimise l'architecture technique de vos projets numériques avec une précision d'ingénieur — vitesse, sécurité et conformité sont ses priorités absolues.",
    competences: [
      "Développement Astro / SSG",
      "Optimisation performance (Core Web Vitals)",
      "Sécurité et conformité nLPD",
      "Intégrations et automatisations",
    ],
  },
  {
    name: "Synergia",
    role: "Coordinatrice & Garante Qualité",
    color: "#f472b6",
    description: "Synergia orchestre les travaux de Lumina et Koda, vérifie la cohérence globale de chaque projet et garantit que chaque livrable respecte vos exigences avant transmission.",
    competences: [
      "Coordination inter-agents",
      "Contrôle qualité des livrables",
      "Vérification conformité légale",
      "Reporting et suivi client",
    ],
  },
];
---

<Layout
  title="L'Équipe CLICOM — Stratège Humain + 3 Agents IA | Corseaux, Vaud"
  description="Mohamed Saber orchestre 3 agents IA spécialisés (Lumina, Koda, Synergia) pour garantir la croissance et la sécurité digitale des PME de Suisse romande."
>

  <!-- ── HERO ───────────────────────────────────────── -->
  <section class="page-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="hero-badge">L'Humain orchestre, l'IA exécute.</span>
      <h1 class="hero-title">Une synergie unique :<br/>L'Humain et l'IA.</h1>
      <p class="hero-text">Découvrez comment un stratège local orchestre la puissance de calcul de 3 agents IA spécialisés pour garantir la croissance et la sécurité de votre PME.</p>
      <div class="hero-actions">
        <a href="#contact" class="btn-lime">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Rencontrer l'équipe — Appel gratuit
        </a>
        <a href="/tarifs" class="btn-outline">Voir les forfaits →</a>
      </div>
    </div>
  </section>

  <!-- ── MOHAMED SABER ──────────────────────────────── -->
  <section class="founder-section">
    <div class="section-inner founder-grid">
      <div class="founder-badge-col" aria-hidden="true">
        <div class="founder-avatar">
          <span class="avatar-initials">MS</span>
          <div class="avatar-ring"></div>
        </div>
        <div class="founder-meta">
          <p class="meta-label">Fondateur</p>
          <p class="meta-location">Corseaux · Vaud · Suisse</p>
        </div>
      </div>
      <div class="founder-content">
        <span class="section-label">Le stratège humain</span>
        <h2 class="section-title">Mohamed Saber</h2>
        <p class="body-text">Stratège digital basé à Corseaux (VD), Mohamed Saber a construit CLICOM sur un constat simple : les PME suisses ont besoin de résultats concrets, pas de rapports incompréhensibles et de réunions sans fin.</p>
        <p class="body-text" style="margin-top:1rem;">Sa méthode : définir la stratégie, piloter les agents IA pour l'exécution, et remettre à chaque client un résultat mesurable — en moins de temps et pour moins cher qu'une agence traditionnelle.</p>
        <div class="founder-tags">
          <span class="tag">Suisse romande</span>
          <span class="tag">Marketing local</span>
          <span class="tag">nLPD</span>
          <span class="tag">Résultats mesurables</span>
        </div>
        <a href="tel:+41788238950" class="founder-tel">+41 78 823 89 50 — Appel direct</a>
      </div>
    </div>
  </section>

  <!-- ── LES 3 AGENTS ───────────────────────────────── -->
  <section class="agents-section">
    <div class="section-inner">
      <div class="section-header centered">
        <span class="section-label">L'équipe IA</span>
        <h2 class="section-title">3 agents. 3 expertises.<br/>Un seul objectif : votre croissance.</h2>
        <p class="section-sub">Chaque agent est entraîné pour une mission précise. Mohamed Saber les coordonne — vous bénéficiez du résultat.</p>
      </div>

      <div class="agents-grid">
        {agents.map(agent => (
          <div class="agent-card">
            <div class="agent-header">
              <div class="agent-icon" style={`background-color: ${agent.color}20; border-color: ${agent.color}30;`}>
                <span class="agent-initial" style={`color: ${agent.color};`}>{agent.name[0]}</span>
              </div>
              <div>
                <p class="agent-name">{agent.name}</p>
                <p class="agent-role">{agent.role}</p>
              </div>
            </div>
            <p class="agent-desc">{agent.description}</p>
            <div class="agent-skills">
              {agent.competences.map(c => (
                <span class="skill-tag">{c}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── COMMENT CA MARCHE ──────────────────────────── -->
  <section class="method-section">
    <div class="section-inner">
      <div class="section-header centered">
        <span class="section-label">Notre modèle</span>
        <h2 class="section-title">Pourquoi c'est plus rapide<br/>et moins cher qu'une agence classique.</h2>
      </div>
      <div class="method-grid">
        <div class="method-col">
          <p class="method-col-title">Agence classique</p>
          {[
            "Chef de projet · Rédacteur · Développeur · Designer · Commercial",
            "Réunions hebdomadaires à facturer",
            "Délai moyen : 3 à 6 mois",
            "Marge d'agence répercutée sur la facture",
            "Rapports mensuels incompréhensibles",
          ].map(item => (
            <div class="method-item method-bad">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
        <div class="method-divider" aria-hidden="true"></div>
        <div class="method-col">
          <p class="method-col-title" style="color: var(--color-brand-lime);">CLICOM</p>
          {[
            "Mohamed Saber + Lumina + Koda + Synergia",
            "Travail asynchrone — zéro réunion inutile",
            "Délai moyen : 21 jours pour un site complet",
            "Gain IA répercuté sur votre facture",
            "Rapport mensuel : appels, visites, résultats",
          ].map(item => (
            <div class="method-item method-good">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTACT ───────────────────────────────────── -->
  <ContactForm
    title="Rencontrez l'équipe. Aucun engagement."
    subtitle="Mohamed Saber vous consacre 30 minutes pour analyser votre situation et vous expliquer exactement comment l'équipe peut vous aider."
  />

</Layout>

<style>
  .page-hero {
    position: relative; overflow: hidden;
    background-color: var(--color-brand-dark);
    padding: 7rem 1.5rem 5rem; text-align: center;
  }
  .hero-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(185,255,102,0.09) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1; max-width: 52rem; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 1.5rem;
  }
  .hero-badge {
    display: inline-block;
    background-color: var(--color-brand-lime-muted);
    border: 1px solid var(--color-border-lime);
    color: var(--color-brand-lime);
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em;
    padding: 0.35rem 1rem; border-radius: var(--radius-full);
  }
  .hero-title { font-size: var(--text-hero); font-weight: 900; color: #fff; line-height: 1.12; letter-spacing: -0.03em; }
  .hero-text { font-size: 1.125rem; color: #9ca3af; line-height: 1.7; max-width: 40rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 0.5rem; }
  .btn-lime {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background-color: var(--color-brand-lime); color: var(--color-brand-dark);
    font-weight: 800; font-size: 1rem; padding: 0.875rem 1.75rem;
    border-radius: var(--radius-xl); text-decoration: none;
    transition: var(--transition-base); box-shadow: var(--shadow-lime);
  }
  .btn-lime:hover { background-color: var(--color-brand-lime-hover); transform: translateY(-2px); }
  .btn-outline {
    display: inline-flex; align-items: center;
    color: #9ca3af; font-weight: 600; font-size: 0.9375rem;
    padding: 0.875rem 1.5rem; border-radius: var(--radius-xl);
    border: 1px solid var(--color-border); text-decoration: none; transition: var(--transition-base);
  }
  .btn-outline:hover { color: #fff; border-color: var(--color-border-strong); }

  /* Founder */
  .founder-section { padding: 5rem 1.5rem; background-color: var(--color-brand-dark-2); border-bottom: 1px solid var(--color-border); }
  .section-inner { max-width: 72rem; margin: 0 auto; }
  .founder-grid { display: grid; grid-template-columns: auto 1fr; gap: 4rem; align-items: start; }
  @media (max-width: 640px) { .founder-grid { grid-template-columns: 1fr; gap: 2rem; } }

  .founder-badge-col { display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .founder-avatar {
    width: 8rem; height: 8rem; border-radius: 50%; position: relative;
    background: linear-gradient(135deg, var(--color-brand-dark-3), var(--color-brand-dark-2));
    border: 2px solid var(--color-border-lime);
    display: flex; align-items: center; justify-content: center;
  }
  .avatar-initials { font-size: 2rem; font-weight: 900; color: var(--color-brand-lime); letter-spacing: 0.05em; }
  .avatar-ring {
    position: absolute; inset: -4px; border-radius: 50%;
    border: 1px solid var(--color-border-lime); opacity: 0.4;
  }
  .founder-meta { text-align: center; }
  .meta-label { font-size: 0.75rem; font-weight: 700; color: var(--color-brand-lime); letter-spacing: 0.08em; text-transform: uppercase; }
  .meta-location { font-size: 0.8rem; color: #4b5563; margin-top: 0.25rem; }

  .founder-content { display: flex; flex-direction: column; gap: 0.75rem; }
  .section-label { font-size: 0.6875rem; font-weight: 800; letter-spacing: 0.10em; text-transform: uppercase; color: var(--color-brand-lime); }
  .section-title { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; color: #fff; line-height: 1.2; }
  .body-text { font-size: 1rem; color: #9ca3af; line-height: 1.75; }
  .founder-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
  .tag {
    font-size: 0.75rem; font-weight: 600; color: #6b7280;
    border: 1px solid var(--color-border); border-radius: var(--radius-full);
    padding: 0.2rem 0.75rem;
  }
  .founder-tel {
    display: inline-block; font-size: 0.9rem; font-weight: 700;
    color: var(--color-brand-lime); text-decoration: none; margin-top: 0.5rem;
    transition: opacity 0.2s;
  }
  .founder-tel:hover { opacity: 0.75; }

  /* Agents */
  .agents-section { padding: 5rem 1.5rem; background-color: var(--color-brand-dark); }
  .section-header { margin-bottom: 3rem; }
  .section-header.centered { text-align: center; }
  .section-sub { font-size: 1rem; color: #6b7280; margin-top: 0.75rem; max-width: 44rem; margin-inline: auto; }
  .agents-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr)); gap: 1.5rem; }
  .agent-card {
    background-color: var(--color-brand-dark-2); border: 1px solid var(--color-border);
    border-radius: var(--radius-3xl); padding: 1.75rem;
    display: flex; flex-direction: column; gap: 1.25rem;
    transition: border-color 0.2s;
  }
  .agent-card:hover { border-color: var(--color-border-lime); }
  .agent-header { display: flex; align-items: center; gap: 1rem; }
  .agent-icon {
    width: 3rem; height: 3rem; border-radius: var(--radius-xl);
    border: 1px solid; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .agent-initial { font-size: 1.25rem; font-weight: 900; }
  .agent-name { font-size: 1.125rem; font-weight: 800; color: #fff; }
  .agent-role { font-size: 0.75rem; color: #6b7280; margin-top: 0.125rem; }
  .agent-desc { font-size: 0.875rem; color: #9ca3af; line-height: 1.7; }
  .agent-skills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .skill-tag {
    font-size: 0.7rem; font-weight: 600; color: #6b7280;
    background-color: var(--color-brand-dark); border: 1px solid var(--color-border);
    border-radius: var(--radius-full); padding: 0.2rem 0.625rem;
  }

  /* Method */
  .method-section { padding: 5rem 1.5rem; background-color: var(--color-brand-dark-2); border-top: 1px solid var(--color-border); }
  .method-grid { display: grid; grid-template-columns: 1fr auto 1fr; gap: 3rem; align-items: start; }
  @media (max-width: 640px) { .method-grid { grid-template-columns: 1fr; } .method-divider { display: none; } }
  .method-col { display: flex; flex-direction: column; gap: 0.875rem; }
  .method-col-title { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: #6b7280; margin-bottom: 0.5rem; }
  .method-divider { width: 1px; background-color: var(--color-border); align-self: stretch; }
  .method-item { display: flex; align-items: flex-start; gap: 0.625rem; font-size: 0.875rem; line-height: 1.5; }
  .method-bad { color: #6b7280; }
  .method-bad svg { color: #4b5563; flex-shrink: 0; margin-top: 0.2rem; }
  .method-good { color: #d1d5db; }
  .method-good svg { color: var(--color-brand-lime); flex-shrink: 0; margin-top: 0.2rem; }
</style>
