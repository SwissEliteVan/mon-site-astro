---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CLICOM | Agence de Marketing Digital Hybride en Suisse" description="L'Humain orchestre, l'IA exécute. Propulsez votre PME suisse avec la vitesse de nos agents intelligents et la sécurité de notre expert local.">
  
  <!-- HERO SECTION (PAGE 1) -->
  <section class="relative min-h-[90vh] flex items-center justify-center pt-20 pb-16 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/assets/medias/agence-marketing-digital-pme-suisse.avif" alt="Bureau d'agence marketing digital en Suisse" width="1920" height="1080" decoding="async" class="w-full h-full object-cover opacity-20" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#191A23]/80 via-[#191A23]/95 to-[#191A23]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block py-1 px-3 rounded-full bg-[#B9FF66]/10 text-[#B9FF66] text-sm font-semibold tracking-wider uppercase mb-6 border border-[#B9FF66]/20">
        Le pragmatisme avant tout
      </span>
      <h1 class="text-[clamp(2.5rem,5vw,4.5rem)] font-extrabold text-white leading-tight mb-8">
        Le digital n'est pas un gadget.<br class="hidden lg:block" />
        <span class="text-[#B9FF66]">C'est un canal de vente vital.</span>
      </h1>
      <p class="text-[clamp(1.125rem,2vw,1.25rem)] text-gray-400 max-w-3xl mx-auto mb-10 leading-relaxed">
        Aujourd'hui, 91 % des consommateurs suisses effectuent des recherches en ligne avant d'acheter localement, et 73 % consultent Google Maps avant de visiter un nouveau commerce. Nous concentrons vos investissements sur ce qui rapporte vraiment.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="#contact" class="w-full sm:w-auto bg-[#B9FF66] text-[#191A23] font-bold px-8 py-4 rounded-xl min-h-[48px] hover:bg-[#a3e655] transition-all focus:ring-2 focus:ring-[#B9FF66] focus:ring-offset-2 focus:ring-offset-[#191A23] shadow-lg shadow-[#B9FF66]/10 text-lg flex items-center justify-center">
          Demander un Audit
        </a>
        <a href="#services" class="w-full sm:w-auto bg-transparent text-white border border-white/20 font-bold px-8 py-4 rounded-xl min-h-[48px] hover:bg-white/5 transition-all text-lg flex items-center justify-center">
          Découvrir nos services
        </a>
      </div>
    </div>
  </section>

  <!-- BANDEAU LOGOS -->
  <section class="py-10 border-y border-white/5 bg-[#191A23]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm font-semibold text-gray-500 uppercase tracking-widest mb-6">Fini les budgets dispersés sans résultats (600 à 1080 CHF gaspillés par mois en moyenne)</p>
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 opacity-50 grayscale">
        <div class="text-xl font-bold text-white">Partenaire 1</div>
        <div class="text-xl font-bold text-white">Partenaire 2</div>
        <div class="text-xl font-bold text-white">Partenaire 3</div>
        <div class="text-xl font-bold text-white">Partenaire 4</div>
        <div class="text-xl font-bold text-white">Partenaire 5</div>
      </div>
    </div>
  </section>

  <!-- SERVICES (BENTO GRID) -->
  <section id="services" class="py-24 bg-[#191A23]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-[clamp(2rem,3vw,3rem)] font-bold text-white mb-4">Concentrez-vous sur ce qui rapporte.</h2>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto">Notre équipe hybride déploie les fondations de votre croissance digitale, avec transparence totale.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-[minmax(350px,auto)]">
        
        <!-- Création Web -->
        <article class="col-span-1 lg:col-span-2 bg-[#1f202b] rounded-3xl overflow-hidden border border-white/10 hover:border-[#B9FF66]/30 transition-all group relative flex flex-col md:flex-row">
          <div class="p-8 md:p-12 flex-1 flex flex-col justify-center z-10">
            <h3 class="text-2xl font-bold text-white mb-4">Création Web & WebPerf</h3>
            <p class="text-gray-400 mb-6 leading-relaxed">Un site esthétique mais lent vous fait perdre des clients. Nos sites vitrines (dès 3'000 CHF) et e-commerces sont ultra-rapides et éco-conçus.</p>
            <a href="/creation-sites-web" class="text-[#B9FF66] font-semibold hover:underline">Découvrir l'offre vitrine &rarr;</a>
          </div>
          <div class="w-full md:w-1/2 relative h-64 md:h-auto">
            <img src="/assets/medias/creation-site-web-performant-suisse.avif" alt="Création de site web performant" width="600" height="400" loading="lazy" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1f202b] via-[#1f202b]/50 md:bg-gradient-to-l to-transparent"></div>
          </div>
        </article>

        <!-- Commerce Local -->
        <article class="bg-[#1f202b] rounded-3xl overflow-hidden border border-white/10 hover:border-[#B9FF66]/30 transition-all group relative flex flex-col">
          <div class="h-48 relative">
            <img src="/assets/medias/digitalisation-commerce-local-carte-nfc.avif" alt="Digitalisation du commerce local NFC" width="400" height="300" loading="lazy" class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1f202b] to-transparent"></div>
          </div>
          <div class="p-8 flex-1 flex flex-col">
            <h3 class="text-2xl font-bold text-white mb-4">Pack Commerce Local</h3>
            <p class="text-gray-400 mb-6">Site SEO, Google Business, fidélité NFC et SMS Marketing (98% d'ouverture).</p>
            <a href="/digitalisation-locale" class="text-[#B9FF66] font-semibold hover:underline mt-auto">Dominer votre quartier &rarr;</a>
          </div>
        </article>

        <!-- Acquisition IA -->
        <article class="col-span-1 lg:col-span-3 bg-[#1f202b] rounded-3xl overflow-hidden border border-white/10 hover:border-[#B9FF66]/30 transition-all group relative">
          <img src="/assets/medias/acquisition-seo-google-ads-ia.avif" alt="Acquisition SEO et Google Ads par IA" width="1200" height="400" loading="lazy" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:scale-105 transition-transform duration-700" />
          <div class="absolute inset-0 bg-[#191A23]/80 group-hover:bg-[#191A23]/60 transition-colors"></div>
          <div class="relative z-10 p-8 md:p-16 text-center max-w-3xl mx-auto">
            <h3 class="text-3xl font-bold text-white mb-4">Acquisition SEO & Ads B2B</h3>
            <p class="text-xl text-gray-300 mb-8">Un trafic qualifié pour des leads concrets. Des forfaits mensuels réalistes dès 1'500 CHF pour générer 5 à 15 leads par mois grâce à l'optimisation IA.</p>
            <a href="/acquisition" class="inline-block bg-white text-[#191A23] font-bold px-8 py-3 rounded-xl hover:bg-gray-200 transition-colors">Générer des leads &rarr;</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- NOTRE METHODOLOGIE (PAGE 5) -->
  <section id="equipe" class="py-24 bg-[#1f202b]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-[clamp(2rem,3vw,3rem)] font-bold text-white mb-4">L'Humain augmenté par la technologie.</h2>
        <p class="text-xl text-gray-400 max-w-3xl mx-auto">L'expertise locale couplée à la puissance technologique. Nos outils IA économisent 30 heures par mois, un gain directement répercuté sur votre facture.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- Mohamed Saber -->
        <div class="bg-[#191A23] p-6 rounded-2xl border border-white/5 hover:border-[#B9FF66]/20 transition-colors">
          <img src="/assets/medias/mohamed-saber-stratege-agence-suisse.avif" alt="Mohamed Saber - Stratège" width="400" height="400" loading="lazy" class="w-full aspect-square object-cover rounded-xl mb-6 shadow-lg" />
          <h3 class="text-xl font-bold text-white">Mohamed Saber</h3>
          <p class="text-[#B9FF66] font-semibold text-sm tracking-wider uppercase mb-3">L'Expert Humain</p>
          <p class="text-gray-400 text-sm">Garant de la stratégie et de l'authenticité. Il comprend votre marché et vos défis locaux.</p>
        </div>

        <!-- Lumina -->
        <div class="bg-[#191A23] p-6 rounded-2xl border border-white/5 hover:border-[#B9FF66]/20 transition-colors">
          <img src="/assets/medias/lumina-agent-ia-webdesign.avif" alt="Lumina - Agent Webdesign" width="400" height="400" loading="lazy" class="w-full aspect-square object-cover rounded-xl mb-6 opacity-90" />
          <h3 class="text-xl font-bold text-white">Lumina</h3>
          <p class="text-[#B9FF66] font-semibold text-sm tracking-wider uppercase mb-3">Agent UX/UI</p>
          <p class="text-gray-400 text-sm">Génère les maquettes design avec une hiérarchie visuelle parfaite pour guider la prise de contact.</p>
        </div>

        <!-- Koda -->
        <div class="bg-[#191A23] p-6 rounded-2xl border border-white/5 hover:border-[#B9FF66]/20 transition-colors">
          <img src="/assets/medias/koda-agent-ia-developpement.avif" alt="Koda - Agent Développement" width="400" height="400" loading="lazy" class="w-full aspect-square object-cover rounded-xl mb-6 opacity-90" />
          <h3 class="text-xl font-bold text-white">Koda</h3>
          <p class="text-[#B9FF66] font-semibold text-sm tracking-wider uppercase mb-3">Agent Développement</p>
          <p class="text-gray-400 text-sm">Produit un code éco-conçu et ultra-rapide pour éliminer les temps d'attente mortels pour vos conversions.</p>
        </div>

        <!-- Synergia -->
        <div class="bg-[#191A23] p-6 rounded-2xl border border-white/5 hover:border-[#B9FF66]/20 transition-colors">
          <img src="/assets/medias/synergia-agent-ia-acquisition.avif" alt="Synergia - Agent Acquisition" width="400" height="400" loading="lazy" class="w-full aspect-square object-cover rounded-xl mb-6 opacity-90" />
          <h3 class="text-xl font-bold text-white">Synergia</h3>
          <p class="text-[#B9FF66] font-semibold text-sm tracking-wider uppercase mb-3">Agent Data</p>
          <p class="text-gray-400 text-sm">Analyse les données publicitaires pour cibler les clics les plus rentables de Suisse romande.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CALL TO ACTION FINAL (PAGE 7) -->
  <section id="contact" class="py-24 bg-[#191A23] relative overflow-hidden border-t border-[#B9FF66]/10">
    <div class="absolute inset-0 z-0">
      <img src="/assets/medias/audit-gratuit-visibilite-digitale.avif" alt="Audit gratuit visibilité digitale" width="1920" height="1080" loading="lazy" class="w-full h-full object-cover opacity-10" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#191A23] via-[#191A23]/80 to-transparent"></div>
    </div>
    
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-[clamp(2.5rem,4vw,3.5rem)] font-bold text-white mb-6">Faites le point sur votre visibilité.</h2>
      <p class="text-xl text-[#B9FF66] font-bold mb-10 border border-[#B9FF66]/30 inline-block px-6 py-3 rounded-full bg-[#B9FF66]/5">
        "L'argent est déjà sur la table. En 1 heure, découvrez exactement combien vous perdez et comment le récupérer."
      </p>
      
      <div class="bg-[#1f202b] p-8 rounded-2xl border border-white/10 shadow-2xl">
        <form class="space-y-6 text-left">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-400 mb-2">Nom & Prénom</label>
              <input type="text" id="name" name="name" class="w-full bg-[#191A23] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#B9FF66] focus:ring-1 focus:ring-[#B9FF66] transition-colors" required>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-400 mb-2">Email professionnel</label>
              <input type="email" id="email" name="email" class="w-full bg-[#191A23] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#B9FF66] focus:ring-1 focus:ring-[#B9FF66] transition-colors" required>
            </div>
          </div>
          <div>
            <label for="website" class="block text-sm font-medium text-gray-400 mb-2">URL de votre site actuel</label>
            <input type="url" id="website" name="website" class="w-full bg-[#191A23] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#B9FF66] focus:ring-1 focus:ring-[#B9FF66] transition-colors">
          </div>
          <button type="submit" class="w-full bg-[#B9FF66] text-[#191A23] font-bold px-8 py-4 rounded-xl hover:bg-[#a3e655] transition-all min-h-[48px] focus:outline-none focus:ring-2 focus:ring-[#B9FF66] focus:ring-offset-2 focus:ring-offset-[#191A23] text-lg">
            Réserver mon Audit Gratuit
          </button>
          <p class="text-xs text-center text-gray-500 mt-4">
            Données sécurisées et traitées selon la <a href="/conformite-nlpd" class="text-[#B9FF66] hover:underline">loi fédérale (nLPD)</a>.
          </p>
        </form>
      </div>
    </div>
  </section>

</Layout>