---
import '../styles/global.css';

// Définition rigoureuse des props avec TypeScript
interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

// Extraction des props avec des valeurs par défaut intelligentes
const { 
  title, 
  description = "Description par défaut de mon site web professionnel créé avec Astro et Tailwind CSS. Optimisé pour les performances et le SEO.",
  image = "/og-image.webp",
  noindex = false
} = Astro.props;

// Construction de l'URL canonique pour le SEO
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
  <head>
    <!-- Balises Meta Indispensables -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    
    <!-- Titre de la page -->
    <title>{title}</title>
    
    <!-- Lien canonique (Évite le duplicate content en SEO) -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Balises Open Graph (OG) pour le partage social (Facebook, LinkedIn, Discord...) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="Mon Projet Astro" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Balises Twitter Card (Pour un affichage riche sur X/Twitter) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />
  </head>

  <!-- selection:bg-indigo-200 améliore l'expérience quand l'utilisateur surligne du texte -->
  <body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col selection:bg-indigo-200 selection:text-indigo-900">
    
    <!-- Lien d'évitement pour l'accessibilité (caché visuellement sauf au focus clavier) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-indigo-600 text-white px-4 py-2 rounded-md z-[100] shadow-lg">
      Aller au contenu principal
    </a>

    <!-- En-tête sémantique <header> -->
    <header class="bg-white/80 backdrop-blur-md shadow-sm sticky top-0 z-50 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="font-bold text-xl tracking-tight text-indigo-600 flex items-center gap-2 hover:opacity-80 transition-opacity focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-md">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <span class="sr-only">Accueil - </span>
          Mon Projet
        </a>
        
        <!-- Navigation sémantique <nav> -->
        <nav class="hidden md:flex space-x-8" aria-label="Menu principal">
          <a href="/" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-md px-2 py-1">Accueil</a>
          <a href="/a-propos" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-md px-2 py-1">À propos</a>
          <a href="/contact" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-md px-2 py-1">Contact</a>
        </nav>
      </div>
    </header>

    <!-- Contenu principal dynamique <main> -->
    <main id="main-content" class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <slot />
    </main>

    <!-- Pied de page sémantique <footer> -->
    <footer class="bg-white border-t border-slate-200 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center text-sm text-slate-500 flex flex-col md:flex-row justify-between items-center gap-4">
        <p>&copy; {new Date().getFullYear()} Mon Projet Astro. Tous droits réservés.</p>
        <div class="flex space-x-6">
          <a href="/mentions-legales" class="hover:text-indigo-600 transition-colors focus:outline-none focus:underline">Mentions légales</a>
          <a href="/confidentialite" class="hover:text-indigo-600 transition-colors focus:outline-none focus:underline">Confidentialité</a>
        </div>
      </div>
    </footer>

  </body>
</html>
