---
// Importation du CSS global
import '../styles/global.css';

import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingContact from '../components/FloatingContact.astro';
import Chatbot from '../components/Chatbot.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { 
  title, 
  description = "CLICOM - Solutions informatiques professionnelles et création de sites web pour PME en Suisse", 
  canonical 
} = Astro.props;

const url = canonical || `https://clicom.ch${Astro.url.pathname}`;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
        return 'dark'; // Par défaut sombre
      })();
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>

    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={url} />
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content="https://clicom.ch/assets/images/agence-marketing-digital-pme-suisse.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="font-sans antialiased flex flex-col min-h-screen bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-300">
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>
    
    <Header />
    
    <main id="main-content" class="flex-grow">
      <slot />
    </main>
    
    <FloatingContact />
    <Chatbot />
    <Footer />

    <style is:global>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #000;
        color: white;
        padding: 8px;
        z-index: 100;
        text-decoration: none;
      }
      .skip-link:focus { top: 0; }
    </style>
  </body>
</html>