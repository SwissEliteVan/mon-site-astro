---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import FloatingContact from '../components/FloatingContact.astro';

// Définition rigoureuse des props avec TypeScript
interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

// Extraction des props avec des valeurs par défaut intelligentes
const { 
  title, 
  description = "Description par défaut de mon site web professionnel créé avec Astro et Tailwind CSS. Optimisé pour les performances et le SEO.",
  image = "/og-image.webp",
  noindex = false
} = Astro.props;

// Construction de l'URL canonique pour le SEO
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
  <head>
    <!-- Balises Meta Indispensables -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    
    <!-- Titre de la page -->
    <title>{title}</title>
    
    <!-- Lien canonique (Évite le duplicate content en SEO) -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Balises Open Graph (OG) pour le partage social (Facebook, LinkedIn, Discord...) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="Mon Projet Astro" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Balises Twitter Card (Pour un affichage riche sur X/Twitter) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />
  </head>

  <!-- selection:bg-indigo-200 améliore l'expérience quand l'utilisateur surligne du texte -->
  <body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col selection:bg-indigo-200 selection:text-indigo-900">
    
    <!-- Lien d'évitement pour l'accessibilité (caché visuellement sauf au focus clavier) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-indigo-600 text-white px-4 py-2 rounded-md z-[100] shadow-lg">
      Aller au contenu principal
    </a>

    <!-- En-tête sémantique <header> -->
    <header class="bg-white/90 backdrop-blur-md shadow-sm sticky top-0 z-50 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center relative">
        <!-- Logo -->
        <a href="/" class="font-bold text-2xl tracking-tight text-slate-900 flex items-center gap-2 hover:opacity-80 transition-opacity focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-md z-20">
          <!-- Icône simple et mémorable -->
          <svg class="w-8 h-8 text-indigo-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13.5h-13L12 6.5z"/>
          </svg>
          Clicom<span class="text-indigo-600">.</span>
        </a>
        
        <!-- Bouton Burger (Mobile) -->
        <button id="menu-toggle" aria-expanded="false" aria-label="Ouvrir le menu" class="lg:hidden z-20 p-2 text-slate-600 hover:text-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-md transition-colors">
          <svg id="menu-icon-open" class="w-7 h-7 block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-7 h-7 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <!-- Navigation Desktop -->
        <nav class="hidden lg:flex items-center space-x-8" aria-label="Menu principal">
          <a href="/" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors px-2 py-1">Accueil</a>
          <a href="/services" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors px-2 py-1">Services</a>
          <a href="/a-propos" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors px-2 py-1">À Propos</a>
          <a href="/realisations" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors px-2 py-1">Réalisations</a>
          <a href="/faq" class="text-slate-600 hover:text-indigo-600 font-medium transition-colors px-2 py-1">FAQ</a>
          <a href="/contact" class="bg-indigo-600 text-white hover:bg-indigo-500 font-bold px-6 py-2.5 rounded-full shadow-sm hover:shadow-md transition-all transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-600">Contact</a>
        </nav>

        <!-- Menu Mobile Overlay -->
        <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 right-0 bg-white border-b border-slate-200 shadow-xl flex-col py-6 px-4 space-y-4">
          <a href="/" class="block text-center text-lg text-slate-700 hover:text-indigo-600 font-medium transition-colors py-2">Accueil</a>
          <a href="/services" class="block text-center text-lg text-slate-700 hover:text-indigo-600 font-medium transition-colors py-2">Services</a>
          <a href="/a-propos" class="block text-center text-lg text-slate-700 hover:text-indigo-600 font-medium transition-colors py-2">À Propos</a>
          <a href="/realisations" class="block text-center text-lg text-slate-700 hover:text-indigo-600 font-medium transition-colors py-2">Réalisations</a>
          <a href="/faq" class="block text-center text-lg text-slate-700 hover:text-indigo-600 font-medium transition-colors py-2">FAQ</a>
          <div class="pt-4 border-t border-slate-100 flex justify-center">
            <a href="/contact" class="bg-indigo-600 text-white hover:bg-indigo-500 font-bold px-8 py-3 rounded-full shadow-sm w-full text-center">Diagnostic Gratuit</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Script minimaliste pour le menu burger (exécuté sur le client) -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const iconOpen = document.getElementById('menu-icon-open');
        const iconClose = document.getElementById('menu-icon-close');

        if (toggle && menu && iconOpen && iconClose) {
          toggle.addEventListener('click', () => {
            const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
            toggle.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
            
            // Toggle classes for menu
            if (menu.classList.contains('hidden')) {
              menu.classList.remove('hidden');
              menu.classList.add('flex');
            } else {
              menu.classList.add('hidden');
              menu.classList.remove('flex');
            }
            
            // Toggle icons
            iconOpen.classList.toggle('hidden');
            iconOpen.classList.toggle('block');
            iconClose.classList.toggle('hidden');
            iconClose.classList.toggle('block');
          });
        }
      });
    </script>

    <!-- Contenu principal dynamique <main> -->
    <main id="main-content" class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <slot />
    </main>

    <!-- Pied de page sémantique <footer> importé via un composant -->
    <Footer />

    <!-- Bandeau de consentement Cookies nLPD -->
    <CookieBanner />

    <!-- Bouton flottant WhatsApp -->
    <FloatingContact />

  </body>
</html>
