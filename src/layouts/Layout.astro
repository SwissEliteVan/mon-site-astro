---
interface Props { title: string; }
const { title } = Astro.props;
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
---
<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preload" href="/fonts/Inter.woff2" as="font" type="font/woff2" crossorigin>
	</head>
<body>
  <Navbar />
  <main class="grid grid-cols-1 gap-y-24 pt-20">
    <slot />
  </main>

		<script defer src="/scripts/lazyload.js" fetchpriority="low"></script>
		<script defer src="/scripts/validation-form.js" fetchpriority="low"></script>
		<script defer src="/scripts/analytics.js" crossorigin="anonymous"></script>
		<script defer src="/scripts/chat-widget.js" crossorigin="anonymous"></script>
	</body>
</html>
