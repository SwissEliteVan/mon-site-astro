---
interface Props {
  title:        string;
  description?: string;
  image?:       string;
  canonical?:   string;
}

const {
  title,
  description = 'Agence web stratégique à Genève — Sites performants, visibilité locale, croissance mesurable.',
  image = '/assets/images/clicom-agence-web-suisse-romande.webp',
  canonical,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://clicom.ch').href;
const ogImage = image.startsWith('http') ? image : `https://clicom.ch${image}`;

import '../styles/global.css';
import Navbar        from '../components/Navbar.astro';
import AntiGravity   from '../components/AntiGravity.astro';
import Footer        from '../components/layout/Footer.astro';
import CookieBanner  from '../components/CookieBanner.astro';
---
<!doctype html>
<html lang="fr" class="overflow-x-hidden w-full m-0 p-0">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── SEO Principal ── -->
    <title>{title}</title>
    <meta name="description"  content={description} />
    <meta name="robots"       content="index, follow" />
    <link rel="canonical"     href={canonicalURL} />

    <!-- ── Open Graph (Facebook / LinkedIn) ── -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="CLICOM" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:locale"      content="fr_CH" />

    <!-- ── Twitter / X Card ── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- ── Polices Google ── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- ── Favicons ── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />
  </head>

  <body class="overflow-x-hidden w-full min-h-screen flex flex-col m-0 p-0 bg-brand-dark text-white antialiased font-sans">
    <Navbar />

    <main class="flex-1 w-full overflow-x-hidden pt-20">
      <slot />
    </main>

    <!-- 🪐 Anti-Gravity — exécution strictement client -->
    <AntiGravity />
    <Footer />

    <!-- 🍪 Bandeau cookies nLPD suisse -->
    <CookieBanner />
  </body>
</html>
