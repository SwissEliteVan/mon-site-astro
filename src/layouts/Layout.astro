---
interface Props {
  title:        string;
  description?: string;
  image?:       string;
}

const {
  title,
  description = 'Agence web stratégique à Genève — Sites performants, visibilité locale, croissance mesurable.',
  image,
} = Astro.props;

import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import AntiGravity from '../components/AntiGravity.astro';
import Footer from '../components/layout/Footer.astro';
---
<!doctype html>
<html lang="fr" class="overflow-x-hidden w-full bg-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />

    <!-- Polices Google (remplace le preload /fonts/Inter.woff2 inexistant) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />
  </head>
  <!-- BING : Les classes anti-barres blanches (overflow-x-hidden, max-w-[100vw], etc.) ont été injectées ici -->
  <body class="overflow-x-hidden w-full max-w-[100vw] min-h-screen flex flex-col m-0 p-0 text-gray-900 antialiased">
    <Navbar />
    <!-- flex-1 pousse le footer vers le bas, overflow-x-hidden blinde le conteneur central -->
    <main class="flex-1 w-full max-w-[100vw] overflow-x-hidden grid grid-cols-1 gap-y-24 pt-20">
      <slot />
    </main>

    <!-- 🪐 Moteur Anti-Gravity — s'exécute uniquement côté client -->
    <AntiGravity />
    <Footer />
  </body>
</html>